<UserControl x:Class="DocumentManagement.Wpf.Views.DocumentListView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:materialDesign="http://materialdesigninxaml.net/winfx/xaml/themes"
             xmlns:conv="clr-namespace:DocumentManagement.Wpf.Converters"
             Background="{StaticResource AppBackgroundBrush}">

    <UserControl.Resources>
        <conv:HexToBrushConverter x:Key="HexToBrushConverter"/>
        <BooleanToVisibilityConverter x:Key="BoolToVisibility"/>

        <Style x:Key="FilterTextBoxStyle" TargetType="TextBox" BasedOn="{StaticResource AppTextBoxStyle}">
            <Setter Property="Height" Value="34"/>
            <Setter Property="FontSize" Value="12"/>
            <Setter Property="Padding" Value="10,0"/>
        </Style>

        <Style x:Key="FilterComboBoxStyle" TargetType="ComboBox" BasedOn="{StaticResource AppComboBoxStyle}">
            <Setter Property="Height" Value="34"/>
            <Setter Property="FontSize" Value="12"/>
        </Style>

        <Style x:Key="DocumentGridTextStyle" TargetType="TextBlock">
            <Setter Property="VerticalAlignment" Value="Center"/>
            <Setter Property="TextTrimming" Value="CharacterEllipsis"/>
            <Setter Property="Foreground" Value="{StaticResource TextBrush}"/>
            <Setter Property="FontSize" Value="12"/>
        </Style>

        <Style x:Key="DocumentGridMutedTextStyle" TargetType="TextBlock" BasedOn="{StaticResource DocumentGridTextStyle}">
            <Setter Property="Foreground" Value="{StaticResource TextMutedBrush}"/>
        </Style>

        <Style x:Key="ActionIconButtonStyle" TargetType="Button">
            <Setter Property="Width" Value="26"/>
            <Setter Property="Height" Value="26"/>
            <Setter Property="Padding" Value="0"/>
            <Setter Property="Margin" Value="1,0"/>
            <Setter Property="Background" Value="Transparent"/>
            <Setter Property="BorderBrush" Value="Transparent"/>
            <Setter Property="Foreground" Value="{StaticResource TextMutedBrush}"/>
            <Setter Property="Cursor" Value="Hand"/>
        </Style>
    </UserControl.Resources>

    <Grid Margin="20">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <Grid Grid.Row="0" Margin="0,0,0,14">
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="14"/>
                <RowDefinition Height="Auto"/>
            </Grid.RowDefinitions>

            <Grid>
            <TextBlock Text="DANH SÁCH VĂN BẢN"
                           FontSize="18"
                           FontWeight="Bold"
                           Foreground="{StaticResource TextBrush}"
                           VerticalAlignment="Center"/>

                <StackPanel Orientation="Horizontal"
                            HorizontalAlignment="Right">
                    <Button Command="{Binding AddCommand}"
                            Style="{StaticResource DangerButtonStyle}"
                            Height="34"
                            Padding="12,0"
                            Margin="0,0,8,0"
                            Visibility="{Binding CanCreateDocument, Converter={StaticResource BoolToVisibility}}">
                        <StackPanel Orientation="Horizontal">
                            <materialDesign:PackIcon Kind="Plus" Width="14" Height="14" VerticalAlignment="Center"/>
                            <TextBlock Text="Thêm văn bản" Margin="6,0,0,0" FontSize="12" VerticalAlignment="Center"/>
                        </StackPanel>
                    </Button>

                    <Button Command="{Binding ExportExcelCommand}"
                            Style="{StaticResource SecondaryButtonStyle}"
                            Height="34"
                            Padding="12,0"
                            Visibility="{Binding CanExportExcel, Converter={StaticResource BoolToVisibility}}">
                        <StackPanel Orientation="Horizontal">
                            <materialDesign:PackIcon Kind="FileExcelOutline" Width="14" Height="14" Foreground="{StaticResource PrimaryBrush}" VerticalAlignment="Center"/>
                            <TextBlock Text="Xuất Excel" Margin="6,0,0,0" FontSize="12" VerticalAlignment="Center"/>
                        </StackPanel>
                    </Button>
                </StackPanel>
            </Grid>

            <Grid Grid.Row="2">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="1.5*"/>
                    <ColumnDefinition Width="12"/>
                    <ColumnDefinition Width="1*"/>
                    <ColumnDefinition Width="12"/>
                    <ColumnDefinition Width="1*"/>
                    <ColumnDefinition Width="12"/>
                    <ColumnDefinition Width="1*"/>
                    <ColumnDefinition Width="12"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>

                <TextBox Grid.Column="0"
                         Style="{StaticResource FilterTextBoxStyle}"
                         Text="{Binding SearchText, UpdateSourceTrigger=PropertyChanged}"
                         materialDesign:HintAssist.Hint="Tìm kiếm theo số ký hiệu, trích yếu..."
                         materialDesign:HintAssist.IsFloating="False"/>

                <ComboBox Grid.Column="2"
                          Style="{StaticResource FilterComboBoxStyle}"
                          ItemsSource="{Binding Categories}"
                          SelectedValue="{Binding SelectedCategoryId}"
                          DisplayMemberPath="Name"
                          SelectedValuePath="Id"
                          materialDesign:HintAssist.Hint="Loại văn bản"
                          materialDesign:HintAssist.IsFloating="False"/>

                <ComboBox Grid.Column="4"
                          Style="{StaticResource FilterComboBoxStyle}"
                          ItemsSource="{Binding Statuses}"
                          SelectedValue="{Binding SelectedStatusId}"
                          DisplayMemberPath="Name"
                          SelectedValuePath="Id"
                          materialDesign:HintAssist.Hint="Trạng thái"
                          materialDesign:HintAssist.IsFloating="False"/>

                <ComboBox Grid.Column="6"
                          Style="{StaticResource FilterComboBoxStyle}"
                          ItemsSource="{Binding UrgencyOptions}"
                          SelectedValue="{Binding SelectedUrgency}"
                          SelectedValuePath="Value"
                          DisplayMemberPath="Text"
                          materialDesign:HintAssist.Hint="Độ khẩn"
                          materialDesign:HintAssist.IsFloating="False"/>

                <Button Grid.Column="8"
                        Command="{Binding ClearFiltersCommand}"
                        Style="{StaticResource SecondaryButtonStyle}"
                        Height="34"
                        Padding="12,0"
                        Content="Xóa lọc"/>
            </Grid>
        </Grid>

        <Border Grid.Row="1"
                Style="{StaticResource AppCardStyle}"
                Padding="0">
            <Grid>
                <DataGrid x:Name="DocumentsDataGrid"
                          MouseDoubleClick="DocumentsDataGrid_MouseDoubleClick"
                          ItemsSource="{Binding Documents}"
                          SelectedItem="{Binding SelectedDocument}"
                          Style="{StaticResource AppDataGridStyle}"
                          AutoGenerateColumns="False"
                          HeadersVisibility="Column"
                          GridLinesVisibility="None"
                          RowHeaderWidth="0"
                          RowHeight="46"
                          ColumnHeaderHeight="40"
                          EnableRowVirtualization="True"
                          EnableColumnVirtualization="True"
                          VirtualizingPanel.IsVirtualizing="True"
                          VirtualizingPanel.VirtualizationMode="Recycling">
                    <DataGrid.Columns>
                        <DataGridTextColumn Header="STT" Width="54" Binding="{Binding Id}" ElementStyle="{StaticResource DocumentGridMutedTextStyle}"/>
                        <DataGridTextColumn Header="Số ký hiệu" Width="120" Binding="{Binding DocumentNumber}" ElementStyle="{StaticResource DocumentGridMutedTextStyle}"/>
                        <DataGridTextColumn Header="Trích yếu" Width="*" Binding="{Binding Title}">
                            <DataGridTextColumn.ElementStyle>
                                <Style TargetType="TextBlock" BasedOn="{StaticResource DocumentGridTextStyle}">
                                    <Setter Property="FontWeight" Value="SemiBold"/>
                                    <Setter Property="ToolTip" Value="{Binding Title}"/>
                                </Style>
                            </DataGridTextColumn.ElementStyle>
                        </DataGridTextColumn>
                        <DataGridTextColumn Header="Loại văn bản" Width="110" Binding="{Binding DocumentType}" ElementStyle="{StaticResource DocumentGridMutedTextStyle}"/>
                        <DataGridTextColumn Header="Cơ quan ban hành" Width="150" Binding="{Binding SenderName}" ElementStyle="{StaticResource DocumentGridMutedTextStyle}"/>
                        <DataGridTextColumn Header="Ngày ban hành" Width="112" Binding="{Binding IssueDate}" ElementStyle="{StaticResource DocumentGridMutedTextStyle}"/>

                        <DataGridTemplateColumn Header="Trạng thái" Width="116">
                            <DataGridTemplateColumn.CellTemplate>
                                <DataTemplate>
                                    <Border Width="84"
                                            Height="24"
                                            CornerRadius="12"
                                            Background="{Binding StatusColor, Converter={StaticResource HexToBrushConverter}}"
                                            HorizontalAlignment="Left">
                                        <TextBlock Text="{Binding StatusText}"
                                                   Foreground="White"
                                                   FontSize="10"
                                                   FontWeight="SemiBold"
                                                   HorizontalAlignment="Center"
                                                   VerticalAlignment="Center"/>
                                    </Border>
                                </DataTemplate>
                            </DataGridTemplateColumn.CellTemplate>
                        </DataGridTemplateColumn>

                        <DataGridTemplateColumn Header="Thao tác" Width="92">
                            <DataGridTemplateColumn.CellTemplate>
                                <DataTemplate>
                                    <StackPanel Orientation="Horizontal" HorizontalAlignment="Center">
                                        <Button Style="{StaticResource ActionIconButtonStyle}" ToolTip="Xem">
                                            <materialDesign:PackIcon Kind="EyeOutline" Width="15" Height="15"/>
                                        </Button>
                                        <Button Style="{StaticResource ActionIconButtonStyle}" ToolTip="Sửa">
                                            <materialDesign:PackIcon Kind="PencilOutline" Width="15" Height="15"/>
                                        </Button>
                                        <Button Style="{StaticResource ActionIconButtonStyle}" ToolTip="Khác">
                                            <materialDesign:PackIcon Kind="DotsVertical" Width="15" Height="15"/>
                                        </Button>
                                    </StackPanel>
                                </DataTemplate>
                            </DataGridTemplateColumn.CellTemplate>
                        </DataGridTemplateColumn>
                    </DataGrid.Columns>
                </DataGrid>

                <Border>
                    <Border.Style>
                        <Style TargetType="Border" BasedOn="{StaticResource EmptyStateContainerStyle}">
                            <Setter Property="Visibility" Value="Visible"/>
                            <Style.Triggers>
                                <DataTrigger Binding="{Binding HasDocuments}" Value="True">
                                    <Setter Property="Visibility" Value="Collapsed"/>
                                </DataTrigger>
                                <DataTrigger Binding="{Binding IsLoading}" Value="True">
                                    <Setter Property="Visibility" Value="Collapsed"/>
                                </DataTrigger>
                            </Style.Triggers>
                        </Style>
                    </Border.Style>
                    <StackPanel HorizontalAlignment="Center" VerticalAlignment="Center">
                        <TextBlock Text="Chưa có dữ liệu" Style="{StaticResource EmptyStateTitleTextStyle}"/>
                        <TextBlock Text="Không tìm thấy văn bản phù hợp với điều kiện hiện tại." Style="{StaticResource EmptyStateDescriptionTextStyle}"/>
                    </StackPanel>
                </Border>
            </Grid>
        </Border>

        <Grid Grid.Row="2" Margin="0,12,0,0">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="Auto"/>
            </Grid.ColumnDefinitions>

            <TextBlock Text="{Binding TotalCount, StringFormat=Hiển thị dữ liệu trong tổng số {0} văn bản}"
                       FontSize="11"
                       Foreground="{StaticResource TextMutedBrush}"
                       VerticalAlignment="Center"/>

            <StackPanel Grid.Column="1" Orientation="Horizontal" VerticalAlignment="Center">
                <Button Command="{Binding PreviousPageCommand}"
                        Style="{StaticResource SecondaryButtonStyle}"
                        Height="32"
                        Width="34"
                        Padding="0"
                        IsEnabled="{Binding CanGoPrevious}">
                    <materialDesign:PackIcon Kind="ChevronLeft" Width="16" Height="16"/>
                </Button>

                <Border MinWidth="80"
                        Height="32"
                        CornerRadius="6"
                        Background="{StaticResource SurfaceBrush}"
                        BorderBrush="{StaticResource BorderBrushDefault}"
                        BorderThickness="1"
                        Margin="8,0"
                        Padding="12,0">
                    <TextBlock Text="{Binding PageDisplayText}" FontSize="12" Foreground="{StaticResource TextBrush}" VerticalAlignment="Center" HorizontalAlignment="Center"/>
                </Border>

                <Button Command="{Binding NextPageCommand}"
                        Style="{StaticResource SecondaryButtonStyle}"
                        Height="32"
                        Width="34"
                        Padding="0"
                        IsEnabled="{Binding CanGoNext}">
                    <materialDesign:PackIcon Kind="ChevronRight" Width="16" Height="16"/>
                </Button>
            </StackPanel>
        </Grid>

        <Grid Grid.RowSpan="3"
              Style="{StaticResource LoadingOverlayGridStyle}"
              Visibility="{Binding IsLoading, Converter={StaticResource BoolToVisibility}}">
            <Border Style="{StaticResource LoadingCardStyle}">
                <StackPanel HorizontalAlignment="Center" VerticalAlignment="Center">
                    <ProgressBar Width="140" Height="6" IsIndeterminate="True" Margin="0,0,0,18"/>
                    <TextBlock Text="Đang tải dữ liệu..." Style="{StaticResource LoadingTextStyle}"/>
                </StackPanel>
            </Border>
        </Grid>
    </Grid>
</UserControl>
