<Window x:Class="DocumentManagement.Wpf.Views.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:materialDesign="http://materialdesigninxaml.net/winfx/xaml/themes"
        xmlns:vm="clr-namespace:DocumentManagement.Wpf.ViewModels"
        xmlns:views="clr-namespace:DocumentManagement.Wpf.Views"
        mc:Ignorable="d"
        Title="Phú Gia Group - Hệ thống Quản lý Văn bản"
        Height="820"
        Width="1360"
        MinHeight="760"
        MinWidth="1180"
        WindowStartupLocation="CenterScreen"
        Background="{StaticResource AppBackgroundBrush}"
        TextElement.Foreground="{StaticResource TextBrush}"
        FontFamily="{StaticResource AppFontFamily}"
        FontSize="13">

    <Window.Resources>
        <BooleanToVisibilityConverter x:Key="BooleanToVisibilityConverter"/>

        <DataTemplate DataType="{x:Type vm:DocumentListViewModel}">
            <views:DocumentListView />
        </DataTemplate>

        <DataTemplate DataType="{x:Type vm:DashboardViewModel}">
            <views:DashboardView />
        </DataTemplate>

        <Style x:Key="SidebarButtonStyle" TargetType="RadioButton">
            <Setter Property="Height" Value="40"/>
            <Setter Property="Margin" Value="8,2"/>
            <Setter Property="Foreground" Value="#E7F4EC"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="RadioButton">
                        <Border x:Name="Root"
                                Background="Transparent"
                                CornerRadius="6"
                                Padding="12,0">
                            <ContentPresenter VerticalAlignment="Center"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="Root" Property="Background" Value="#187A47"/>
                            </Trigger>
                            <Trigger Property="IsChecked" Value="True">
                                <Setter TargetName="Root" Property="Background" Value="#1B8B50"/>
                                <Setter Property="Foreground" Value="White"/>
                            </Trigger>
                            <Trigger Property="IsEnabled" Value="False">
                                <Setter Property="Opacity" Value="0.48"/>
                                <Setter Property="Cursor" Value="Arrow"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Style x:Key="SidebarActionButtonStyle" TargetType="Button">
            <Setter Property="Height" Value="38"/>
            <Setter Property="Margin" Value="8,2"/>
            <Setter Property="Padding" Value="12,0"/>
            <Setter Property="Foreground" Value="#E7F4EC"/>
            <Setter Property="Background" Value="Transparent"/>
            <Setter Property="BorderBrush" Value="Transparent"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="HorizontalContentAlignment" Value="Stretch"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border x:Name="Root"
                                Background="{TemplateBinding Background}"
                                CornerRadius="6"
                                Padding="{TemplateBinding Padding}">
                            <ContentPresenter VerticalAlignment="Center"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="Root" Property="Background" Value="#187A47"/>
                            </Trigger>
                            <Trigger Property="IsPressed" Value="True">
                                <Setter TargetName="Root" Property="Background" Value="#0A5C31"/>
                            </Trigger>
                            <Trigger Property="IsEnabled" Value="False">
                                <Setter TargetName="Root" Property="Opacity" Value="0.48"/>
                                <Setter Property="Cursor" Value="Arrow"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Style x:Key="TopIconButtonStyle" TargetType="Button">
            <Setter Property="Width" Value="34"/>
            <Setter Property="Height" Value="34"/>
            <Setter Property="Background" Value="Transparent"/>
            <Setter Property="BorderBrush" Value="Transparent"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="Foreground" Value="{StaticResource TextMutedBrush}"/>
            <Setter Property="Cursor" Value="Hand"/>
        </Style>
    </Window.Resources>

    <Grid Background="{StaticResource AppBackgroundBrush}">
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="136"/>
            <ColumnDefinition Width="*"/>
        </Grid.ColumnDefinitions>

        <Border Grid.Column="0" Background="#004B28">
            <DockPanel LastChildFill="True">
                <Button DockPanel.Dock="Bottom"
                        Style="{StaticResource SidebarActionButtonStyle}"
                        Click="ExitButton_Click"
                        Margin="8,0,8,12">
                    <StackPanel Orientation="Horizontal">
                        <materialDesign:PackIcon Kind="Logout"
                                                 Width="15"
                                                 Height="15"
                                                 Foreground="#E7F4EC"
                                                 VerticalAlignment="Center"/>
                        <TextBlock Text="Thu gọn"
                                   Margin="9,0,0,0"
                                   Foreground="#E7F4EC"
                                   FontSize="12"
                                   VerticalAlignment="Center"/>
                    </StackPanel>
                </Button>

                <StackPanel DockPanel.Dock="Top">
                    <Border Height="92"
                            Padding="18,10"
                            BorderBrush="#12683C"
                            BorderThickness="0,0,0,1">
                        <Image Source="pack://application:,,,/Assets/Images/logo-tach.png"
                               Stretch="Uniform"/>
                    </Border>

                    <RadioButton Style="{StaticResource SidebarButtonStyle}"
                                 IsChecked="True"
                                 Command="{Binding ShowDashboardCommand}"
                                 Visibility="{Binding CanViewDashboard, Converter={StaticResource BooleanToVisibilityConverter}}"
                                 GroupName="MenuMain">
                        <StackPanel Orientation="Horizontal">
                            <materialDesign:PackIcon Kind="HomeOutline" Width="15" Height="15" Foreground="{Binding RelativeSource={RelativeSource AncestorType=RadioButton}, Path=Foreground}" VerticalAlignment="Center"/>
                            <TextBlock Text="Tổng quan" Margin="9,0,0,0" Foreground="{Binding RelativeSource={RelativeSource AncestorType=RadioButton}, Path=Foreground}" FontSize="12" VerticalAlignment="Center"/>
                        </StackPanel>
                    </RadioButton>

                    <RadioButton Style="{StaticResource SidebarButtonStyle}"
                                 Command="{Binding ShowDocumentListCommand}"
                                 Visibility="{Binding CanViewDocuments, Converter={StaticResource BooleanToVisibilityConverter}}"
                                 GroupName="MenuMain">
                        <StackPanel Orientation="Horizontal">
                            <materialDesign:PackIcon Kind="FileDocumentOutline" Width="15" Height="15" Foreground="{Binding RelativeSource={RelativeSource AncestorType=RadioButton}, Path=Foreground}" VerticalAlignment="Center"/>
                            <TextBlock Text="Văn bản" Margin="9,0,0,0" Foreground="{Binding RelativeSource={RelativeSource AncestorType=RadioButton}, Path=Foreground}" FontSize="12" VerticalAlignment="Center"/>
                        </StackPanel>
                    </RadioButton>

                    <RadioButton Style="{StaticResource SidebarButtonStyle}" IsEnabled="False" GroupName="MenuMain">
                        <StackPanel Orientation="Horizontal">
                            <materialDesign:PackIcon Kind="PencilBoxOutline" Width="15" Height="15" Foreground="{Binding RelativeSource={RelativeSource AncestorType=RadioButton}, Path=Foreground}" VerticalAlignment="Center"/>
                            <TextBlock Text="Soạn thảo" Margin="9,0,0,0" Foreground="{Binding RelativeSource={RelativeSource AncestorType=RadioButton}, Path=Foreground}" FontSize="12" VerticalAlignment="Center"/>
                        </StackPanel>
                    </RadioButton>

                    <RadioButton Style="{StaticResource SidebarButtonStyle}" IsEnabled="False" GroupName="MenuMain">
                        <StackPanel Orientation="Horizontal">
                            <materialDesign:PackIcon Kind="CheckboxMarkedCircleOutline" Width="15" Height="15" Foreground="{Binding RelativeSource={RelativeSource AncestorType=RadioButton}, Path=Foreground}" VerticalAlignment="Center"/>
                            <TextBlock Text="Duyệt văn bản" Margin="9,0,0,0" Foreground="{Binding RelativeSource={RelativeSource AncestorType=RadioButton}, Path=Foreground}" FontSize="12" VerticalAlignment="Center"/>
                        </StackPanel>
                    </RadioButton>

                    <RadioButton Style="{StaticResource SidebarButtonStyle}" IsEnabled="False" GroupName="MenuMain">
                        <StackPanel Orientation="Horizontal">
                            <materialDesign:PackIcon Kind="ArchiveOutline" Width="15" Height="15" Foreground="{Binding RelativeSource={RelativeSource AncestorType=RadioButton}, Path=Foreground}" VerticalAlignment="Center"/>
                            <TextBlock Text="Lưu trữ" Margin="9,0,0,0" Foreground="{Binding RelativeSource={RelativeSource AncestorType=RadioButton}, Path=Foreground}" FontSize="12" VerticalAlignment="Center"/>
                        </StackPanel>
                    </RadioButton>

                    <RadioButton Style="{StaticResource SidebarButtonStyle}" IsEnabled="False" GroupName="MenuMain">
                        <StackPanel Orientation="Horizontal">
                            <materialDesign:PackIcon Kind="ChartBar" Width="15" Height="15" Foreground="{Binding RelativeSource={RelativeSource AncestorType=RadioButton}, Path=Foreground}" VerticalAlignment="Center"/>
                            <TextBlock Text="Báo cáo" Margin="9,0,0,0" Foreground="{Binding RelativeSource={RelativeSource AncestorType=RadioButton}, Path=Foreground}" FontSize="12" VerticalAlignment="Center"/>
                        </StackPanel>
                    </RadioButton>

                    <RadioButton Style="{StaticResource SidebarButtonStyle}" IsEnabled="False" GroupName="MenuMain">
                        <StackPanel Orientation="Horizontal">
                            <materialDesign:PackIcon Kind="TagMultipleOutline" Width="15" Height="15" Foreground="{Binding RelativeSource={RelativeSource AncestorType=RadioButton}, Path=Foreground}" VerticalAlignment="Center"/>
                            <TextBlock Text="Danh mục" Margin="9,0,0,0" Foreground="{Binding RelativeSource={RelativeSource AncestorType=RadioButton}, Path=Foreground}" FontSize="12" VerticalAlignment="Center"/>
                        </StackPanel>
                    </RadioButton>

                    <RadioButton Style="{StaticResource SidebarButtonStyle}"
                                 Visibility="{Binding CanViewSettings, Converter={StaticResource BooleanToVisibilityConverter}}"
                                 IsEnabled="False"
                                 GroupName="MenuMain">
                        <StackPanel Orientation="Horizontal">
                            <materialDesign:PackIcon Kind="CogOutline" Width="15" Height="15" Foreground="{Binding RelativeSource={RelativeSource AncestorType=RadioButton}, Path=Foreground}" VerticalAlignment="Center"/>
                            <TextBlock Text="Hệ thống" Margin="9,0,0,0" Foreground="{Binding RelativeSource={RelativeSource AncestorType=RadioButton}, Path=Foreground}" FontSize="12" VerticalAlignment="Center"/>
                        </StackPanel>
                    </RadioButton>

                    <Separator Margin="14,10" Background="#12683C"/>

                    <Button Style="{StaticResource SidebarActionButtonStyle}"
                            Command="{Binding BackupCommand}"
                            Visibility="{Binding CanBackup, Converter={StaticResource BooleanToVisibilityConverter}}">
                        <StackPanel Orientation="Horizontal">
                            <materialDesign:PackIcon Kind="DatabaseArrowUpOutline" Width="15" Height="15" Foreground="#E7F4EC" VerticalAlignment="Center"/>
                            <TextBlock Text="Backup" Margin="9,0,0,0" Foreground="#E7F4EC" FontSize="12" VerticalAlignment="Center"/>
                        </StackPanel>
                    </Button>

                    <Button Style="{StaticResource SidebarActionButtonStyle}"
                            Command="{Binding RestoreCommand}"
                            Visibility="{Binding CanRestore, Converter={StaticResource BooleanToVisibilityConverter}}">
                        <StackPanel Orientation="Horizontal">
                            <materialDesign:PackIcon Kind="DatabaseRefreshOutline" Width="15" Height="15" Foreground="#E7F4EC" VerticalAlignment="Center"/>
                            <TextBlock Text="Restore" Margin="9,0,0,0" Foreground="#E7F4EC" FontSize="12" VerticalAlignment="Center"/>
                        </StackPanel>
                    </Button>
                </StackPanel>
            </DockPanel>
        </Border>

        <Grid Grid.Column="1">
            <Grid.RowDefinitions>
                <RowDefinition Height="58"/>
                <RowDefinition Height="*"/>
            </Grid.RowDefinitions>

            <Border Grid.Row="0"
                    Background="{StaticResource SurfaceBrush}"
                    BorderBrush="{StaticResource BorderBrushDefault}"
                    BorderThickness="0,0,0,1">
                <Grid Margin="20,0">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="Auto"/>
                    </Grid.ColumnDefinitions>

                    <Border Width="330"
                            Height="34"
                            HorizontalAlignment="Right"
                            VerticalAlignment="Center"
                            Margin="0,0,24,0"
                            Background="#FBFCFB"
                            BorderBrush="{StaticResource BorderBrushDefault}"
                            BorderThickness="1"
                            CornerRadius="6">
                        <Grid Margin="10,0">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="22"/>
                            </Grid.ColumnDefinitions>
                            <TextBox Text="{Binding QuickSearchText, UpdateSourceTrigger=PropertyChanged}"
                                     Background="Transparent"
                                     BorderThickness="0"
                                     Foreground="{StaticResource TextBrush}"
                                     FontSize="12"
                                     VerticalContentAlignment="Center"
                                     materialDesign:HintAssist.Hint="Tìm kiếm văn bản, hồ sơ..."
                                     materialDesign:HintAssist.IsFloating="False"
                                     materialDesign:TextFieldAssist.DecorationVisibility="Hidden"/>
                            <materialDesign:PackIcon Grid.Column="1"
                                                     Kind="Magnify"
                                                     Width="14"
                                                     Height="14"
                                                     Foreground="{StaticResource TextMutedBrush}"
                                                     VerticalAlignment="Center"/>
                        </Grid>
                    </Border>

                    <StackPanel Grid.Column="1"
                                Orientation="Horizontal"
                                VerticalAlignment="Center">
                        <Button Style="{StaticResource TopIconButtonStyle}" ToolTip="Thông báo">
                            <materialDesign:PackIcon Kind="BellOutline" Width="18" Height="18"/>
                        </Button>

                        <Border Width="30"
                                Height="30"
                                CornerRadius="15"
                                Margin="12,0,10,0"
                                Background="#5F6864">
                            <TextBlock Text="NV"
                                       Foreground="White"
                                       FontSize="11"
                                       FontWeight="Bold"
                                       HorizontalAlignment="Center"
                                       VerticalAlignment="Center"/>
                        </Border>

                        <StackPanel VerticalAlignment="Center" MinWidth="112">
                            <TextBlock Text="{Binding CurrentDisplayName}"
                                       FontSize="12"
                                       FontWeight="SemiBold"
                                       Foreground="{StaticResource TextBrush}"
                                       TextTrimming="CharacterEllipsis"/>
                            <TextBlock Text="{Binding CurrentDepartmentName}"
                                       FontSize="10"
                                       Foreground="{StaticResource TextMutedBrush}"/>
                        </StackPanel>

                        <materialDesign:PackIcon Kind="ChevronDown"
                                                 Width="16"
                                                 Height="16"
                                                 Foreground="{StaticResource TextMutedBrush}"
                                                 VerticalAlignment="Center"
                                                 Margin="8,0,0,0"/>
                    </StackPanel>
                </Grid>
            </Border>

            <ContentControl Grid.Row="1"
                            Content="{Binding CurrentView}"
                            ClipToBounds="True"
                            HorizontalContentAlignment="Stretch"
                            VerticalContentAlignment="Stretch"/>
        </Grid>
    </Grid>
</Window>
