<Window x:Class="DocumentManagement.Wpf.Views.DocumentFormWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Thông tin văn bản"
        Height="800"
        Width="980"
        MinHeight="720"
        MinWidth="920"
        WindowStartupLocation="CenterOwner"
        ResizeMode="CanResize"
        Background="{StaticResource AppBackgroundBrush}"
        FontFamily="{StaticResource AppFontFamily}"
        FontSize="13">

    <Window.Resources>
        <BooleanToVisibilityConverter x:Key="BoolToVisibility"/>

        <Style x:Key="LabelStyle" TargetType="TextBlock">
            <Setter Property="Margin" Value="0,0,0,6"/>
            <Setter Property="Foreground" Value="{StaticResource TextBrush}"/>
            <Setter Property="FontWeight" Value="SemiBold"/>
            <Setter Property="FontSize" Value="13"/>
        </Style>

        <Style x:Key="RequiredLabelStyle"
               TargetType="TextBlock"
               BasedOn="{StaticResource LabelStyle}">
            <Setter Property="Foreground" Value="{StaticResource TextBrush}"/>
        </Style>

        <Style x:Key="FormFieldPanelStyle" TargetType="StackPanel">
            <Setter Property="Margin" Value="0,0,0,14"/>
        </Style>

        <Style x:Key="LeftFormFieldPanelStyle"
               TargetType="StackPanel"
               BasedOn="{StaticResource FormFieldPanelStyle}">
            <Setter Property="Margin" Value="0,0,10,14"/>
        </Style>

        <Style x:Key="RightFormFieldPanelStyle"
               TargetType="StackPanel"
               BasedOn="{StaticResource FormFieldPanelStyle}">
            <Setter Property="Margin" Value="10,0,0,14"/>
        </Style>

        <Style x:Key="BadgeBaseStyle" TargetType="Border">
            <Setter Property="CornerRadius" Value="999"/>
            <Setter Property="Padding" Value="12,6"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="VerticalAlignment" Value="Center"/>
        </Style>

        <Style x:Key="ReadonlyBadgeStyle"
               TargetType="Border"
               BasedOn="{StaticResource BadgeBaseStyle}">
            <Setter Property="Background" Value="#FEF3C7"/>
            <Setter Property="BorderBrush" Value="#FDE68A"/>
            <Setter Property="Margin" Value="0,0,8,0"/>
        </Style>

        <Style x:Key="ApiModeBadgeStyle"
               TargetType="Border"
               BasedOn="{StaticResource BadgeBaseStyle}">
            <Setter Property="Background" Value="#ECFDF5"/>
            <Setter Property="BorderBrush" Value="#BBF7D0"/>
        </Style>

        <Style x:Key="FileNameTextStyle" TargetType="TextBlock">
            <Setter Property="VerticalAlignment" Value="Center"/>
            <Setter Property="TextTrimming" Value="CharacterEllipsis"/>
            <Setter Property="MaxWidth" Value="360"/>
            <Setter Property="Foreground" Value="{StaticResource TextMutedBrush}"/>
            <Setter Property="FontStyle" Value="Italic"/>
        </Style>
    </Window.Resources>

    <Grid Margin="20">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <!-- HEADER -->
        <Border Grid.Row="0"
                Style="{StaticResource AppCardStyle}"
                Padding="18"
                Margin="0,0,0,14">

            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>

                <StackPanel>
                    <TextBlock Text="Thông tin văn bản"
                               FontSize="24"
                               FontWeight="Bold"
                               Foreground="{StaticResource TextBrush}"/>

                    <TextBlock Margin="0,6,0,0">
                        <TextBlock.Style>
                            <Style TargetType="TextBlock" BasedOn="{StaticResource MutedTextStyle}">
                                <Setter Property="Text" Value="Tạo mới hoặc cập nhật văn bản qua API."/>
                                <Style.Triggers>
                                    <DataTrigger Binding="{Binding IsReadOnlyMode}" Value="True">
                                        <Setter Property="Text" Value="Đang mở văn bản ở chế độ xem. Bạn không thể chỉnh sửa nội dung."/>
                                    </DataTrigger>
                                </Style.Triggers>
                            </Style>
                        </TextBlock.Style>
                    </TextBlock>
                </StackPanel>

                <StackPanel Grid.Column="1"
                            Orientation="Horizontal"
                            VerticalAlignment="Center">

                    <Border Style="{StaticResource ReadonlyBadgeStyle}"
                            Visibility="{Binding IsReadOnlyMode, Converter={StaticResource BoolToVisibility}}">
                        <TextBlock Text="Chế độ xem"
                                   Foreground="#92400E"
                                   FontWeight="SemiBold"
                                   FontSize="12"/>
                    </Border>

                    <Border Style="{StaticResource ApiModeBadgeStyle}">
                        <TextBlock Text="Client-server: CRUD qua API"
                                   Foreground="#166534"
                                   FontWeight="SemiBold"
                                   FontSize="12"/>
                    </Border>
                </StackPanel>
            </Grid>
        </Border>

        <!-- BODY -->
        <Border Grid.Row="1"
                Style="{StaticResource AppCardStyle}"
                Padding="16">

            <Grid>
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="*"/>
                </Grid.RowDefinitions>

                <!-- UPLOAD -->
                <Border Grid.Row="0"
                        Style="{StaticResource SoftCardStyle}"
                        Padding="12"
                        Margin="0,0,0,14">

                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="Auto"/>
                            <ColumnDefinition Width="Auto"/>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="Auto"/>
                        </Grid.ColumnDefinitions>

                        <TextBlock Grid.Column="0"
                                   Text="File PDF:"
                                   VerticalAlignment="Center"
                                   Margin="0,0,10,0"
                                   FontWeight="SemiBold"
                                   Foreground="{StaticResource TextBrush}"/>

                        <Button Grid.Column="1"
                                Content="Chọn file"
                                Width="104"
                                Height="36"
                                Style="{StaticResource SecondaryButtonStyle}"
                                Command="{Binding BrowseFileCommand}"
                                IsEnabled="{Binding CanBrowseFile}"
                                Margin="0,0,12,0"/>

                        <TextBlock Grid.Column="2"
                                   Text="{Binding SelectedFilePath}"
                                   Style="{StaticResource FileNameTextStyle}"/>

                        <Button Grid.Column="3"
                                Content="Tự động điền từ PDF"
                                Width="180"
                                Height="36"
                                Style="{StaticResource PrimaryButtonStyle}"
                                Command="{Binding AutoFillCommand}"
                                IsEnabled="{Binding CanAutoFill}"/>
                    </Grid>
                </Border>

                <!-- FORM -->
                <ScrollViewer Grid.Row="1"
                              VerticalScrollBarVisibility="Auto"
                              HorizontalScrollBarVisibility="Disabled"
                              Padding="0,0,6,0">

                    <Grid IsEnabled="{Binding CanModifyDocument}">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="*"/>
                        </Grid.ColumnDefinitions>

                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="Auto"/>
                        </Grid.RowDefinitions>

                        <StackPanel Grid.Row="0"
                                    Grid.Column="0"
                                    Style="{StaticResource LeftFormFieldPanelStyle}">
                            <TextBlock Text="Loại văn bản" Style="{StaticResource LabelStyle}"/>
                            <ComboBox SelectedValue="{Binding DocumentType}"
                                      SelectedValuePath="Tag"
                                      Style="{StaticResource AppComboBoxStyle}">
                                <ComboBoxItem Content="Văn bản đến" Tag="INCOMING"/>
                                <ComboBoxItem Content="Văn bản đi" Tag="OUTGOING"/>
                            </ComboBox>
                        </StackPanel>

                        <StackPanel Grid.Row="0"
                                    Grid.Column="1"
                                    Style="{StaticResource RightFormFieldPanelStyle}">
                            <TextBlock Text="Số hiệu văn bản (*)" Style="{StaticResource RequiredLabelStyle}"/>
                            <TextBox Text="{Binding DocumentNumber, UpdateSourceTrigger=PropertyChanged}"
                                     Style="{StaticResource AppTextBoxStyle}"/>
                        </StackPanel>

                        <StackPanel Grid.Row="1"
                                    Grid.ColumnSpan="2"
                                    Style="{StaticResource FormFieldPanelStyle}">
                            <TextBlock Text="Tiêu đề / Trích yếu văn bản (*)" Style="{StaticResource RequiredLabelStyle}"/>
                            <TextBox Text="{Binding Title, UpdateSourceTrigger=PropertyChanged}"
                                     FontWeight="SemiBold"
                                     Style="{StaticResource AppTextBoxStyle}"/>
                        </StackPanel>

                        <StackPanel Grid.Row="2"
                                    Grid.Column="0"
                                    Style="{StaticResource LeftFormFieldPanelStyle}">
                            <TextBlock Text="Số ký hiệu / Số phụ" Style="{StaticResource LabelStyle}"/>
                            <TextBox Text="{Binding ReferenceNumber}"
                                     Style="{StaticResource AppTextBoxStyle}"/>
                        </StackPanel>

                        <StackPanel Grid.Row="2"
                                    Grid.Column="1"
                                    Style="{StaticResource RightFormFieldPanelStyle}">
                            <TextBlock Text="Danh mục văn bản" Style="{StaticResource LabelStyle}"/>
                            <ComboBox ItemsSource="{Binding Categories}"
                                      SelectedValue="{Binding CategoryId}"
                                      SelectedValuePath="Id"
                                      DisplayMemberPath="Name"
                                      Style="{StaticResource AppComboBoxStyle}"/>
                        </StackPanel>

                        <StackPanel Grid.Row="3"
                                    Grid.Column="0"
                                    Style="{StaticResource LeftFormFieldPanelStyle}">
                            <TextBlock Text="Ngày ban hành" Style="{StaticResource LabelStyle}"/>
                            <DatePicker SelectedDate="{Binding IssueDate}"
                                        Style="{StaticResource AppDatePickerStyle}"/>
                        </StackPanel>

                        <StackPanel Grid.Row="3"
                                    Grid.Column="1"
                                    Style="{StaticResource RightFormFieldPanelStyle}">
                            <TextBlock Text="Trạng thái" Style="{StaticResource LabelStyle}"/>
                            <ComboBox ItemsSource="{Binding Statuses}"
                                      SelectedValue="{Binding StatusId}"
                                      SelectedValuePath="Id"
                                      DisplayMemberPath="Name"
                                      IsEnabled="False"
                                      Style="{StaticResource AppComboBoxStyle}"/>
                        </StackPanel>

                        <StackPanel Grid.Row="4"
                                    Grid.Column="0"
                                    Style="{StaticResource LeftFormFieldPanelStyle}">
                            <TextBlock Text="Ngày nhận" Style="{StaticResource LabelStyle}"/>
                            <DatePicker SelectedDate="{Binding ReceivedDate}"
                                        Style="{StaticResource AppDatePickerStyle}"/>
                        </StackPanel>

                        <StackPanel Grid.Row="4"
                                    Grid.Column="1"
                                    Style="{StaticResource RightFormFieldPanelStyle}">
                            <TextBlock Text="Hạn xử lý" Style="{StaticResource LabelStyle}"/>
                            <DatePicker SelectedDate="{Binding DueDate}"
                                        Style="{StaticResource AppDatePickerStyle}"/>
                        </StackPanel>

                        <StackPanel Grid.Row="5"
                                    Grid.Column="0"
                                    Style="{StaticResource LeftFormFieldPanelStyle}">
                            <TextBlock Text="Cơ quan ban hành / Người gửi" Style="{StaticResource LabelStyle}"/>
                            <TextBox Text="{Binding SenderName}"
                                     Style="{StaticResource AppTextBoxStyle}"/>
                        </StackPanel>

                        <StackPanel Grid.Row="5"
                                    Grid.Column="1"
                                    Style="{StaticResource RightFormFieldPanelStyle}">
                            <TextBlock Text="Nơi nhận / Người nhận" Style="{StaticResource LabelStyle}"/>
                            <TextBox Text="{Binding ReceiverName}"
                                     Style="{StaticResource AppTextBoxStyle}"/>
                        </StackPanel>

                        <StackPanel Grid.Row="6"
                                    Grid.Column="0"
                                    Style="{StaticResource LeftFormFieldPanelStyle}">
                            <TextBlock Text="Người ký" Style="{StaticResource LabelStyle}"/>
                            <TextBox Text="{Binding SignerName}"
                                     Style="{StaticResource AppTextBoxStyle}"/>
                        </StackPanel>

                        <StackPanel Grid.Row="6"
                                    Grid.Column="1"
                                    Style="{StaticResource RightFormFieldPanelStyle}">
                            <TextBlock Text="Phòng ban chủ trì" Style="{StaticResource LabelStyle}"/>
                            <TextBox Text="{Binding ProcessingDepartment}"
                                     Style="{StaticResource AppTextBoxStyle}"/>
                        </StackPanel>

                        <StackPanel Grid.Row="7"
                                    Grid.Column="0"
                                    Style="{StaticResource LeftFormFieldPanelStyle}">
                            <TextBlock Text="Người được giao xử lý" Style="{StaticResource LabelStyle}"/>
                            <TextBox Text="{Binding AssignedTo}"
                                     Style="{StaticResource AppTextBoxStyle}"/>
                        </StackPanel>

                        <StackPanel Grid.Row="7"
                                    Grid.Column="1"
                                    Style="{StaticResource RightFormFieldPanelStyle}">
                            <TextBlock Text="Độ mật" Style="{StaticResource LabelStyle}"/>
                            <ComboBox SelectedValue="{Binding ConfidentialityLevel}"
                                      SelectedValuePath="Tag"
                                      Style="{StaticResource AppComboBoxStyle}">
                                <ComboBoxItem Content="Bình thường" Tag="NORMAL"/>
                                <ComboBoxItem Content="Mật" Tag="CONFIDENTIAL"/>
                                <ComboBoxItem Content="Tối mật" Tag="SECRET"/>
                                <ComboBoxItem Content="Tuyệt mật" Tag="TOP_SECRET"/>
                            </ComboBox>
                        </StackPanel>

                        <StackPanel Grid.Row="8"
                                    Grid.Column="0"
                                    Style="{StaticResource LeftFormFieldPanelStyle}">
                            <TextBlock Text="Độ khẩn" Style="{StaticResource LabelStyle}"/>
                            <ComboBox SelectedValue="{Binding UrgencyLevel}"
                                      SelectedValuePath="Tag"
                                      Style="{StaticResource AppComboBoxStyle}">
                                <ComboBoxItem Content="Bình thường" Tag="NORMAL"/>
                                <ComboBoxItem Content="Khẩn" Tag="URGENT"/>
                                <ComboBoxItem Content="Hỏa tốc" Tag="VERY_URGENT"/>
                            </ComboBox>
                        </StackPanel>

                        <StackPanel Grid.Row="8"
                                    Grid.Column="1"
                                    Style="{StaticResource RightFormFieldPanelStyle}">
                            <TextBlock Text="Ghi chú" Style="{StaticResource LabelStyle}"/>
                            <TextBox Text="{Binding Notes}"
                                     Style="{StaticResource AppTextBoxStyle}"/>
                        </StackPanel>

                        <StackPanel Grid.Row="9"
                                    Grid.ColumnSpan="2"
                                    Style="{StaticResource FormFieldPanelStyle}">
                            <TextBlock Text="Trích yếu nội dung" Style="{StaticResource LabelStyle}"/>
                            <TextBox Text="{Binding Summary}"
                                     Height="84"
                                     TextWrapping="Wrap"
                                     AcceptsReturn="True"
                                     VerticalContentAlignment="Top"
                                     Style="{StaticResource AppTextBoxStyle}"/>
                        </StackPanel>

                        <StackPanel Grid.Row="10"
                                    Grid.ColumnSpan="2">
                            <TextBlock Text="Nội dung văn bản"
                                       Style="{StaticResource LabelStyle}"/>
                            <TextBox Text="{Binding ContentText}"
                                     Height="150"
                                     TextWrapping="Wrap"
                                     AcceptsReturn="True"
                                     VerticalContentAlignment="Top"
                                     VerticalScrollBarVisibility="Auto"
                                     Style="{StaticResource AppTextBoxStyle}"/>
                        </StackPanel>
                    </Grid>
                </ScrollViewer>
            </Grid>
        </Border>

        <!-- FOOTER -->
        <Border Grid.Row="2"
                Padding="0,14,0,0"
                BorderBrush="{StaticResource BorderBrushDefault}"
                BorderThickness="0,1,0,0"
                Margin="0,14,0,0">

            <DockPanel LastChildFill="False">

                <Button Content="Xóa văn bản"
                        DockPanel.Dock="Left"
                        Width="130"
                        Height="40"
                        Style="{StaticResource DangerButtonStyle}"
                        Command="{Binding DeleteCommand}"
                        IsEnabled="{Binding CanDelete}"
                        Visibility="{Binding CanDelete, Converter={StaticResource BoolToVisibility}}"
                        CommandParameter="{Binding RelativeSource={RelativeSource AncestorType=Window}}"/>

                <StackPanel Orientation="Horizontal"
                            DockPanel.Dock="Right"
                            HorizontalAlignment="Right">

                    <Button Width="100"
                            Height="40"
                            IsCancel="True"
                            Margin="0,0,10,0">
                        <Button.Style>
                            <Style TargetType="Button" BasedOn="{StaticResource SecondaryButtonStyle}">
                                <Setter Property="Content" Value="Hủy bỏ"/>
                                <Style.Triggers>
                                    <DataTrigger Binding="{Binding IsReadOnlyMode}" Value="True">
                                        <Setter Property="Content" Value="Đóng"/>
                                    </DataTrigger>
                                </Style.Triggers>
                            </Style>
                        </Button.Style>
                    </Button>

                    <Button Content="Lưu văn bản"
                            Width="150"
                            Height="40"
                            Style="{StaticResource SuccessButtonStyle}"
                            Command="{Binding SaveCommand}"
                            IsEnabled="{Binding CanSaveDocument}"
                            Visibility="{Binding CanSaveDocument, Converter={StaticResource BoolToVisibility}}"
                            CommandParameter="{Binding RelativeSource={RelativeSource AncestorType=Window}}"/>
                </StackPanel>
            </DockPanel>
        </Border>
    </Grid>
</Window>