<UserControl x:Class="DocumentManagement.Wpf.Views.DashboardView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:lvc="clr-namespace:LiveCharts.Wpf;assembly=LiveCharts.Wpf"
             xmlns:materialDesign="http://materialdesigninxaml.net/winfx/xaml/themes"
             xmlns:conv="clr-namespace:DocumentManagement.Wpf.Converters"
             Background="#EAF5EE"
             UseLayoutRounding="True"
             SnapsToDevicePixels="True">

    <UserControl.Resources>
        <conv:StatusNameToBrushConverter x:Key="StatusNameToBrushConverter"/>
        <BooleanToVisibilityConverter x:Key="BoolToVisibility"/>

        <SolidColorBrush x:Key="DashboardGreen" Color="#2FA52C"/>
        <SolidColorBrush x:Key="DashboardGreenDark" Color="#168333"/>
        <SolidColorBrush x:Key="DashboardGreenSoft" Color="#EEF8EC"/>
        <SolidColorBrush x:Key="DashboardBorder" Color="#259323"/>
        <SolidColorBrush x:Key="DashboardGridLine" Color="#D9ECDD"/>

        <Style x:Key="DashboardPanelStyle" TargetType="Border">
            <Setter Property="Background" Value="#FFFFFC"/>
            <Setter Property="BorderBrush" Value="{StaticResource DashboardBorder}"/>
            <Setter Property="BorderThickness" Value="1.2"/>
            <Setter Property="Padding" Value="0"/>
            <Setter Property="SnapsToDevicePixels" Value="True"/>
        </Style>

        <Style x:Key="PanelTitleStyle" TargetType="TextBlock">
            <Setter Property="Height" Value="30"/>
            <Setter Property="Padding" Value="10,6,10,0"/>
            <Setter Property="Background" Value="#F5FBF3"/>
            <Setter Property="Foreground" Value="#2B2F2D"/>
            <Setter Property="FontSize" Value="14"/>
            <Setter Property="FontWeight" Value="SemiBold"/>
            <Setter Property="TextAlignment" Value="Center"/>
        </Style>

        <Style x:Key="MetricBoxStyle" TargetType="Border">
            <Setter Property="Height" Value="94"/>
            <Setter Property="Margin" Value="0,0,0,8"/>
            <Setter Property="Background" Value="#FFFFFC"/>
            <Setter Property="BorderBrush" Value="{StaticResource DashboardBorder}"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="Padding" Value="10,8"/>
        </Style>

        <Style x:Key="MetricLabelStyle" TargetType="TextBlock">
            <Setter Property="Foreground" Value="#244238"/>
            <Setter Property="FontSize" Value="11"/>
            <Setter Property="FontWeight" Value="Bold"/>
            <Setter Property="TextAlignment" Value="Center"/>
            <Setter Property="TextWrapping" Value="Wrap"/>
        </Style>

        <Style x:Key="MetricValueStyle" TargetType="TextBlock">
            <Setter Property="Foreground" Value="{StaticResource DashboardGreenDark}"/>
            <Setter Property="FontSize" Value="22"/>
            <Setter Property="FontWeight" Value="Bold"/>
            <Setter Property="TextAlignment" Value="Center"/>
            <Setter Property="Margin" Value="0,8,0,0"/>
        </Style>

        <Style x:Key="GridTextStyle" TargetType="TextBlock">
            <Setter Property="VerticalAlignment" Value="Center"/>
            <Setter Property="TextTrimming" Value="CharacterEllipsis"/>
            <Setter Property="Foreground" Value="{StaticResource TextBrush}"/>
            <Setter Property="FontSize" Value="12"/>
        </Style>

        <Style x:Key="GridMutedTextStyle" TargetType="TextBlock" BasedOn="{StaticResource GridTextStyle}">
            <Setter Property="Foreground" Value="{StaticResource TextMutedBrush}"/>
        </Style>
    </UserControl.Resources>

    <Grid>
        <Border Margin="14"
                Background="#FFFFFC"
                BorderBrush="{StaticResource DashboardBorder}"
                BorderThickness="1.4">
            <Grid Margin="8">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="146"/>
                    <ColumnDefinition Width="8"/>
                    <ColumnDefinition Width="*"/>
                </Grid.ColumnDefinitions>

                <StackPanel Grid.Column="0">
                    <Border Style="{StaticResource MetricBoxStyle}">
                        <StackPanel VerticalAlignment="Center">
                            <TextBlock Text="TỔNG VĂN BẢN" Style="{StaticResource MetricLabelStyle}"/>
                            <TextBlock Text="{Binding TotalDocuments, StringFormat={}{0:N0}}" Style="{StaticResource MetricValueStyle}"/>
                        </StackPanel>
                    </Border>

                    <Border Style="{StaticResource MetricBoxStyle}">
                        <StackPanel VerticalAlignment="Center">
                            <TextBlock Text="ĐÃ BAN HÀNH" Style="{StaticResource MetricLabelStyle}"/>
                            <TextBlock Text="{Binding IssuedDocuments, StringFormat={}{0:N0}}" Style="{StaticResource MetricValueStyle}"/>
                        </StackPanel>
                    </Border>

                    <Border Style="{StaticResource MetricBoxStyle}">
                        <StackPanel VerticalAlignment="Center">
                            <TextBlock Text="CÒN HIỆU LỰC" Style="{StaticResource MetricLabelStyle}"/>
                            <TextBlock Text="{Binding EffectiveDocuments, StringFormat={}{0:N0}}" Style="{StaticResource MetricValueStyle}"/>
                        </StackPanel>
                    </Border>

                    <Border Style="{StaticResource MetricBoxStyle}">
                        <StackPanel VerticalAlignment="Center">
                            <TextBlock Text="HẾT HIỆU LỰC" Style="{StaticResource MetricLabelStyle}"/>
                            <TextBlock Text="{Binding ExpiredDocuments, StringFormat={}{0:N0}}" Style="{StaticResource MetricValueStyle}"/>
                        </StackPanel>
                    </Border>

                    <Border Style="{StaticResource MetricBoxStyle}" Height="112">
                        <StackPanel VerticalAlignment="Center">
                            <TextBlock Text="TB BAN HÀNH / THÁNG" Style="{StaticResource MetricLabelStyle}"/>
                            <TextBlock Text="{Binding AverageIssuedPerMonth, StringFormat={}{0:N1}}" Style="{StaticResource MetricValueStyle}"/>
                        </StackPanel>
                    </Border>
                </StackPanel>

                <Grid Grid.Column="2">
                    <Grid.RowDefinitions>
                        <RowDefinition Height="42"/>
                        <RowDefinition Height="8"/>
                        <RowDefinition Height="*"/>
                    </Grid.RowDefinitions>

                    <Grid Grid.Row="0">
                        <Border Background="{StaticResource DashboardGreen}">
                            <TextBlock Text="TỔNG QUAN VĂN BẢN"
                                       Foreground="White"
                                       FontSize="20"
                                       FontWeight="Bold"
                                       TextAlignment="Center"
                                       VerticalAlignment="Center"/>
                        </Border>

                        <Border Width="118"
                                Height="34"
                                HorizontalAlignment="Right"
                                VerticalAlignment="Center"
                                Margin="0,0,8,0"
                                Background="#FFFFFC"
                                BorderBrush="#E2B66C"
                                BorderThickness="1"
                                Padding="8,3">
                            <Image Source="pack://application:,,,/Assets/Images/logo-tach.png"
                                   Stretch="Uniform"
                                   RenderOptions.BitmapScalingMode="HighQuality"/>
                        </Border>
                    </Grid>

                    <Grid Grid.Row="2">
                        <Grid.RowDefinitions>
                            <RowDefinition Height="1*"/>
                            <RowDefinition Height="8"/>
                            <RowDefinition Height="1*"/>
                        </Grid.RowDefinitions>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="1.08*"/>
                            <ColumnDefinition Width="8"/>
                            <ColumnDefinition Width="1*"/>
                        </Grid.ColumnDefinitions>

                        <Border Grid.Row="0"
                                Grid.Column="0"
                                Style="{StaticResource DashboardPanelStyle}">
                            <Grid>
                                <Grid.RowDefinitions>
                                    <RowDefinition Height="30"/>
                                    <RowDefinition Height="*"/>
                                </Grid.RowDefinitions>
                                <TextBlock Text="Văn bản ban hành theo tháng" Style="{StaticResource PanelTitleStyle}"/>
                                <lvc:CartesianChart Grid.Row="1"
                                                    Margin="10,4,10,8"
                                                    Series="{Binding MonthlyIssuedSeries}"
                                                    LegendLocation="Top">
                                    <lvc:CartesianChart.AxisX>
                                        <lvc:Axis Labels="{Binding MonthlyIssuedLabels}" Separator="{x:Static lvc:DefaultAxes.CleanSeparator}"/>
                                    </lvc:CartesianChart.AxisX>
                                    <lvc:CartesianChart.AxisY>
                                        <lvc:Axis MinValue="0"/>
                                    </lvc:CartesianChart.AxisY>
                                </lvc:CartesianChart>
                            </Grid>
                        </Border>

                        <Border Grid.Row="0"
                                Grid.Column="2"
                                Style="{StaticResource DashboardPanelStyle}">
                            <Grid>
                                <Grid.RowDefinitions>
                                    <RowDefinition Height="30"/>
                                    <RowDefinition Height="*"/>
                                </Grid.RowDefinitions>
                                <TextBlock Text="Văn bản theo phòng ban" Style="{StaticResource PanelTitleStyle}"/>
                                <lvc:CartesianChart Grid.Row="1"
                                                    Margin="10,4,10,8"
                                                    Series="{Binding DepartmentIssuedSeries}"
                                                    LegendLocation="None">
                                    <lvc:CartesianChart.AxisX>
                                        <lvc:Axis Labels="{Binding DepartmentIssuedLabels}" Separator="{x:Static lvc:DefaultAxes.CleanSeparator}"/>
                                    </lvc:CartesianChart.AxisX>
                                    <lvc:CartesianChart.AxisY>
                                        <lvc:Axis MinValue="0"/>
                                    </lvc:CartesianChart.AxisY>
                                </lvc:CartesianChart>
                            </Grid>
                        </Border>

                        <Border Grid.Row="2"
                                Grid.Column="0"
                                Style="{StaticResource DashboardPanelStyle}">
                            <Grid>
                                <Grid.RowDefinitions>
                                    <RowDefinition Height="30"/>
                                    <RowDefinition Height="*"/>
                                </Grid.RowDefinitions>
                                <TextBlock Text="Văn bản mới ban hành" Style="{StaticResource PanelTitleStyle}"/>
                                <DataGrid x:Name="RecentDocumentsGrid"
                                          Grid.Row="1"
                                          ItemsSource="{Binding RecentDocuments}"
                                          Style="{StaticResource AppDataGridStyle}"
                                          AutoGenerateColumns="False"
                                          HeadersVisibility="Column"
                                          GridLinesVisibility="None"
                                          RowHeaderWidth="0"
                                          RowHeight="38"
                                          ColumnHeaderHeight="34"
                                          MouseDoubleClick="RecentDocumentsGrid_MouseDoubleClick">
                                    <DataGrid.Columns>
                                        <DataGridTextColumn Header="Số ký hiệu" Binding="{Binding DocumentNumber}" Width="116" ElementStyle="{StaticResource GridMutedTextStyle}"/>
                                        <DataGridTextColumn Header="Trích yếu" Binding="{Binding Title}" Width="*" ElementStyle="{StaticResource GridTextStyle}"/>
                                        <DataGridTextColumn Header="Ngày cập nhật" Binding="{Binding UpdatedAt, StringFormat=dd/MM}" Width="104" ElementStyle="{StaticResource GridMutedTextStyle}"/>
                                    </DataGrid.Columns>
                                </DataGrid>
                            </Grid>
                        </Border>

                        <Border Grid.Row="2"
                                Grid.Column="2"
                                Style="{StaticResource DashboardPanelStyle}">
                            <Grid>
                                <Grid.RowDefinitions>
                                    <RowDefinition Height="30"/>
                                    <RowDefinition Height="*"/>
                                </Grid.RowDefinitions>
                                <TextBlock Text="Cơ cấu hiệu lực văn bản" Style="{StaticResource PanelTitleStyle}"/>
                                <Grid Grid.Row="1" Margin="8">
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="*"/>
                                        <ColumnDefinition Width="130"/>
                                    </Grid.ColumnDefinitions>

                                    <lvc:PieChart Series="{Binding EffectivenessSeries}"
                                                  LegendLocation="None"
                                                  HoverPushOut="4"
                                                  InnerRadius="58"/>

                                    <StackPanel Grid.Column="1"
                                                VerticalAlignment="Center"
                                                Margin="10,0,0,0">
                                        <TextBlock Text="Tổng văn bản"
                                                   Foreground="{StaticResource TextMutedBrush}"
                                                   FontSize="12"
                                                   TextAlignment="Center"/>
                                        <TextBlock Text="{Binding TotalDocuments, StringFormat={}{0:N0}}"
                                                   Foreground="{StaticResource DashboardGreenDark}"
                                                   FontSize="24"
                                                   FontWeight="Bold"
                                                   TextAlignment="Center"
                                                   Margin="0,4,0,12"/>
                                        <TextBlock Text="{Binding TopIssuingDepartment, StringFormat=Đơn vị nổi bật: {0}}"
                                                   Foreground="{StaticResource TextMutedBrush}"
                                                   FontSize="11"
                                                   TextWrapping="Wrap"
                                                   TextAlignment="Center"/>
                                    </StackPanel>
                                </Grid>
                            </Grid>
                        </Border>
                    </Grid>
                </Grid>
            </Grid>
        </Border>

        <Grid Style="{StaticResource LoadingOverlayGridStyle}"
              Visibility="{Binding IsLoading, Converter={StaticResource BoolToVisibility}}">
            <Border Style="{StaticResource LoadingCardStyle}">
                <StackPanel HorizontalAlignment="Center" VerticalAlignment="Center">
                    <ProgressBar Width="140" Height="6" IsIndeterminate="True" Margin="0,0,0,18"/>
                    <TextBlock Text="Đang tải dashboard..." Style="{StaticResource LoadingTextStyle}"/>
                </StackPanel>
            </Border>
        </Grid>

        <Border Style="{StaticResource ErrorBannerStyle}"
                Visibility="{Binding HasError, Converter={StaticResource BoolToVisibility}}">
            <TextBlock Text="{Binding ErrorMessage}" Style="{StaticResource ErrorBannerTextStyle}"/>
        </Border>
    </Grid>
</UserControl>
