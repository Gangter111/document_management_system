<UserControl x:Class="DocumentManagement.Wpf.Views.DashboardView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:lvc="clr-namespace:LiveCharts.Wpf;assembly=LiveCharts.Wpf"
             xmlns:conv="clr-namespace:DocumentManagement.Wpf.Converters"
             Background="{StaticResource AppBackgroundBrush}">

    <UserControl.Resources>
        <conv:StatusNameToBrushConverter x:Key="StatusNameToBrushConverter"/>
        <BooleanToVisibilityConverter x:Key="BoolToVisibility"/>

        <Style x:Key="RecentGridTextStyle" TargetType="TextBlock">
            <Setter Property="VerticalAlignment" Value="Center"/>
            <Setter Property="TextTrimming" Value="CharacterEllipsis"/>
            <Setter Property="Foreground" Value="{StaticResource TextBrush}"/>
            <Setter Property="FontSize" Value="13"/>
        </Style>

        <Style x:Key="RecentGridMutedTextStyle"
               TargetType="TextBlock"
               BasedOn="{StaticResource RecentGridTextStyle}">
            <Setter Property="Foreground" Value="{StaticResource TextMutedBrush}"/>
        </Style>

        <Style x:Key="RecentGridCellStyle" TargetType="DataGridCell">
            <Setter Property="Padding" Value="12,0"/>
            <Setter Property="VerticalContentAlignment" Value="Center"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="FocusVisualStyle" Value="{x:Null}"/>
            <Setter Property="Background" Value="Transparent"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="DataGridCell">
                        <Border Background="{TemplateBinding Background}"
                                Padding="{TemplateBinding Padding}">
                            <ContentPresenter VerticalAlignment="Center"/>
                        </Border>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Style x:Key="RecentGridRowStyle" TargetType="DataGridRow">
            <Setter Property="Height" Value="48"/>
            <Setter Property="MinHeight" Value="48"/>
            <Setter Property="Background" Value="Transparent"/>
            <Setter Property="BorderBrush" Value="{StaticResource BorderBrushDefault}"/>
            <Setter Property="BorderThickness" Value="0,0,0,1"/>
            <Setter Property="SnapsToDevicePixels" Value="True"/>
            <Style.Triggers>
                <Trigger Property="IsMouseOver" Value="True">
                    <Setter Property="Background" Value="#F8FAFC"/>
                </Trigger>
                <Trigger Property="IsSelected" Value="True">
                    <Setter Property="Background" Value="#EEF2FF"/>
                </Trigger>
            </Style.Triggers>
        </Style>

        <Style x:Key="RecentGridColumnHeaderStyle" TargetType="DataGridColumnHeader">
            <Setter Property="Height" Value="42"/>
            <Setter Property="Padding" Value="12,0"/>
            <Setter Property="Background" Value="#F8FAFC"/>
            <Setter Property="Foreground" Value="{StaticResource TextMutedBrush}"/>
            <Setter Property="FontSize" Value="12"/>
            <Setter Property="FontWeight" Value="SemiBold"/>
            <Setter Property="BorderBrush" Value="{StaticResource BorderBrushDefault}"/>
            <Setter Property="BorderThickness" Value="0,0,0,1"/>
            <Setter Property="HorizontalContentAlignment" Value="Left"/>
            <Setter Property="VerticalContentAlignment" Value="Center"/>
        </Style>
    </UserControl.Resources>

    <Grid>
        <ScrollViewer VerticalScrollBarVisibility="Auto">
            <StackPanel Margin="24">

                <DockPanel Margin="0,0,0,20">
                    <StackPanel DockPanel.Dock="Left">
                        <TextBlock Text="Bảng điều khiển"
                                   Style="{StaticResource PageTitleTextStyle}"/>

                        <TextBlock Text="Theo dõi tổng số văn bản, hiệu lực, phòng ban ban hành và xu hướng theo tháng."
                                   Margin="0,6,0,0"
                                   Style="{StaticResource MutedTextStyle}"/>
                    </StackPanel>

                    <Button Content="Làm mới"
                            Width="110"
                            Height="38"
                            Style="{StaticResource SecondaryButtonStyle}"
                            Command="{Binding RefreshCommand}"
                            DockPanel.Dock="Right"/>
                </DockPanel>

                <UniformGrid Columns="5" Margin="0,0,0,18">

                    <Border Style="{StaticResource HoverCardStyle}" Margin="0,0,12,0">
                        <StackPanel>
                            <TextBlock Text="Tổng số văn bản" Style="{StaticResource MutedTextStyle}"/>
                            <TextBlock Text="{Binding TotalDocuments}"
                                       FontSize="32"
                                       FontWeight="Bold"
                                       Foreground="{StaticResource TextBrush}"/>
                        </StackPanel>
                    </Border>

                    <Border Style="{StaticResource HoverCardStyle}" Margin="0,0,12,0">
                        <StackPanel>
                            <TextBlock Text="Đã ban hành" Style="{StaticResource MutedTextStyle}"/>
                            <TextBlock Text="{Binding IssuedDocuments}"
                                       FontSize="32"
                                       FontWeight="Bold"
                                       Foreground="{StaticResource SuccessBrush}"/>
                        </StackPanel>
                    </Border>

                    <Border Style="{StaticResource HoverCardStyle}" Margin="0,0,12,0">
                        <StackPanel>
                            <TextBlock Text="Có hiệu lực" Style="{StaticResource MutedTextStyle}"/>
                            <TextBlock Text="{Binding EffectiveDocuments}"
                                       FontSize="32"
                                       FontWeight="Bold"
                                       Foreground="#059669"/>
                        </StackPanel>
                    </Border>

                    <Border Style="{StaticResource HoverCardStyle}" Margin="0,0,12,0">
                        <StackPanel>
                            <TextBlock Text="Hết hiệu lực" Style="{StaticResource MutedTextStyle}"/>
                            <TextBlock Text="{Binding ExpiredDocuments}"
                                       FontSize="32"
                                       FontWeight="Bold"
                                       Foreground="{StaticResource DangerBrush}"/>
                        </StackPanel>
                    </Border>

                    <Border Style="{StaticResource HoverCardStyle}">
                        <StackPanel>
                            <TextBlock Text="TB ban hành/tháng" Style="{StaticResource MutedTextStyle}"/>
                            <TextBlock Text="{Binding AverageIssuedPerMonth, StringFormat={}{0:N1}}"
                                       FontSize="32"
                                       FontWeight="Bold"
                                       Foreground="{StaticResource PrimaryBrush}"/>
                        </StackPanel>
                    </Border>

                </UniformGrid>

                <Border Style="{StaticResource AppCardStyle}" Margin="0,0,0,18">
                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="1.4*"/>
                            <ColumnDefinition Width="Auto"/>
                            <ColumnDefinition Width="1*"/>
                        </Grid.ColumnDefinitions>

                        <StackPanel Grid.Column="0">
                            <TextBlock Text="Phòng ban ban hành nhiều nhất"
                                       Style="{StaticResource MutedTextStyle}"/>

                            <TextBlock Text="{Binding TopIssuingDepartment}"
                                       Margin="0,6,0,0"
                                       FontSize="24"
                                       FontWeight="Bold"
                                       Foreground="{StaticResource TextBrush}"
                                       TextTrimming="CharacterEllipsis"/>

                            <TextBlock Text="{Binding TopIssuingDepartmentCount, StringFormat=Số văn bản: {0}}"
                                       Margin="0,6,0,0"
                                       Style="{StaticResource SmallMutedTextStyle}"/>
                        </StackPanel>

                        <Border Grid.Column="1"
                                Width="1"
                                Margin="24,0"
                                Background="{StaticResource BorderBrushDefault}"/>

                        <StackPanel Grid.Column="2">
                            <TextBlock Text="Ghi chú thống kê"
                                       Style="{StaticResource MutedTextStyle}"/>

                            <TextBlock Text="Có hiệu lực = văn bản đã ban hành và chưa hết hạn xử lý / chưa bị đánh dấu hết hiệu lực."
                                       Margin="0,8,0,0"
                                       TextWrapping="Wrap"
                                       Style="{StaticResource SmallMutedTextStyle}"/>

                            <TextBlock Text="Biểu đồ tháng lấy theo ngày ban hành trong 12 tháng gần nhất."
                                       Margin="0,6,0,0"
                                       TextWrapping="Wrap"
                                       Style="{StaticResource SmallMutedTextStyle}"/>
                        </StackPanel>
                    </Grid>
                </Border>

                <Grid Margin="0,0,0,18">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="1*"/>
                        <ColumnDefinition Width="1.7*"/>
                    </Grid.ColumnDefinitions>

                    <Border Grid.Column="0"
                            Style="{StaticResource AppCardStyle}"
                            Margin="0,0,12,0">
                        <StackPanel>
                            <TextBlock Text="Cơ cấu hiệu lực"
                                       Style="{StaticResource SectionTitleTextStyle}"
                                       Margin="0,0,0,12"/>

                            <Grid Height="280">
                                <lvc:PieChart Series="{Binding EffectivenessSeries}"
                                              LegendLocation="Bottom"
                                              HoverPushOut="8">
                                    <lvc:PieChart.Style>
                                        <Style TargetType="lvc:PieChart">
                                            <Setter Property="Visibility" Value="Visible"/>
                                            <Style.Triggers>
                                                <DataTrigger Binding="{Binding HasEffectivenessChartData}" Value="False">
                                                    <Setter Property="Visibility" Value="Collapsed"/>
                                                </DataTrigger>
                                            </Style.Triggers>
                                        </Style>
                                    </lvc:PieChart.Style>
                                </lvc:PieChart>

                                <Border>
                                    <Border.Style>
                                        <Style TargetType="Border" BasedOn="{StaticResource SoftCardStyle}">
                                            <Setter Property="Visibility" Value="Collapsed"/>
                                            <Style.Triggers>
                                                <DataTrigger Binding="{Binding HasEffectivenessChartData}" Value="False">
                                                    <Setter Property="Visibility" Value="Visible"/>
                                                </DataTrigger>
                                            </Style.Triggers>
                                        </Style>
                                    </Border.Style>

                                    <TextBlock Text="Chưa có dữ liệu hiệu lực"
                                               HorizontalAlignment="Center"
                                               VerticalAlignment="Center"
                                               Style="{StaticResource MutedTextStyle}"/>
                                </Border>
                            </Grid>
                        </StackPanel>
                    </Border>

                    <Border Grid.Column="1"
                            Style="{StaticResource AppCardStyle}">
                        <StackPanel>
                            <TextBlock Text="Văn bản ban hành theo tháng"
                                       Style="{StaticResource SectionTitleTextStyle}"
                                       Margin="0,0,0,12"/>

                            <Grid Height="280">
                                <lvc:CartesianChart Series="{Binding MonthlyIssuedSeries}"
                                                    LegendLocation="Top">
                                    <lvc:CartesianChart.AxisX>
                                        <lvc:Axis Labels="{Binding MonthlyIssuedLabels}"
                                                  Separator="{x:Static lvc:DefaultAxes.CleanSeparator}"/>
                                    </lvc:CartesianChart.AxisX>
                                    <lvc:CartesianChart.AxisY>
                                        <lvc:Axis MinValue="0"/>
                                    </lvc:CartesianChart.AxisY>

                                    <lvc:CartesianChart.Style>
                                        <Style TargetType="lvc:CartesianChart">
                                            <Setter Property="Visibility" Value="Visible"/>
                                            <Style.Triggers>
                                                <DataTrigger Binding="{Binding HasMonthlyIssuedChartData}" Value="False">
                                                    <Setter Property="Visibility" Value="Collapsed"/>
                                                </DataTrigger>
                                            </Style.Triggers>
                                        </Style>
                                    </lvc:CartesianChart.Style>
                                </lvc:CartesianChart>

                                <Border>
                                    <Border.Style>
                                        <Style TargetType="Border" BasedOn="{StaticResource SoftCardStyle}">
                                            <Setter Property="Visibility" Value="Collapsed"/>
                                            <Style.Triggers>
                                                <DataTrigger Binding="{Binding HasMonthlyIssuedChartData}" Value="False">
                                                    <Setter Property="Visibility" Value="Visible"/>
                                                </DataTrigger>
                                            </Style.Triggers>
                                        </Style>
                                    </Border.Style>

                                    <TextBlock Text="Chưa có dữ liệu theo tháng"
                                               HorizontalAlignment="Center"
                                               VerticalAlignment="Center"
                                               Style="{StaticResource MutedTextStyle}"/>
                                </Border>
                            </Grid>
                        </StackPanel>
                    </Border>
                </Grid>

                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="1.35*"/>
                        <ColumnDefinition Width="1*"/>
                    </Grid.ColumnDefinitions>

                    <Border Grid.Column="0"
                            Style="{StaticResource AppCardStyle}"
                            Margin="0,0,12,0">

                        <StackPanel>
                            <TextBlock Text="Văn bản gần đây"
                                       Style="{StaticResource SectionTitleTextStyle}"
                                       Margin="0,0,0,14"/>

                            <DataGrid x:Name="RecentDocumentsGrid"
                                      ItemsSource="{Binding RecentDocuments}"
                                      Style="{StaticResource AppDataGridStyle}"
                                      AutoGenerateColumns="False"
                                      HeadersVisibility="Column"
                                      GridLinesVisibility="None"
                                      RowHeaderWidth="0"
                                      RowHeight="48"
                                      MinRowHeight="48"
                                      ColumnHeaderHeight="42"
                                      CanUserAddRows="False"
                                      CanUserDeleteRows="False"
                                      CanUserResizeRows="False"
                                      SelectionMode="Single"
                                      SelectionUnit="FullRow"
                                      CellStyle="{StaticResource RecentGridCellStyle}"
                                      RowStyle="{StaticResource RecentGridRowStyle}"
                                      ColumnHeaderStyle="{StaticResource RecentGridColumnHeaderStyle}"
                                      MouseDoubleClick="RecentDocumentsGrid_MouseDoubleClick">

                                <DataGrid.Columns>
                                    <DataGridTextColumn Header="Mã VB"
                                                        Binding="{Binding DocumentNumber}"
                                                        Width="130"
                                                        ElementStyle="{StaticResource RecentGridMutedTextStyle}"/>

                                    <DataGridTextColumn Header="Tiêu đề"
                                                        Binding="{Binding Title}"
                                                        Width="*">
                                        <DataGridTextColumn.ElementStyle>
                                            <Style TargetType="TextBlock"
                                                   BasedOn="{StaticResource RecentGridTextStyle}">
                                                <Setter Property="FontWeight" Value="SemiBold"/>
                                                <Setter Property="ToolTip" Value="{Binding Title}"/>
                                            </Style>
                                        </DataGridTextColumn.ElementStyle>
                                    </DataGridTextColumn>

                                    <DataGridTemplateColumn Header="Trạng thái" Width="145">
                                        <DataGridTemplateColumn.CellTemplate>
                                            <DataTemplate>
                                                <Grid VerticalAlignment="Center">
                                                    <Border Style="{StaticResource BadgeBorderStyle}"
                                                            Height="26"
                                                            MinWidth="92"
                                                            HorizontalAlignment="Left"
                                                            VerticalAlignment="Center"
                                                            Background="{Binding StatusText, Converter={StaticResource StatusNameToBrushConverter}}">
                                                        <TextBlock Text="{Binding StatusText}"
                                                                   Style="{StaticResource BadgeTextStyle}"
                                                                   VerticalAlignment="Center"
                                                                   HorizontalAlignment="Center"/>
                                                    </Border>
                                                </Grid>
                                            </DataTemplate>
                                        </DataGridTemplateColumn.CellTemplate>
                                    </DataGridTemplateColumn>

                                    <DataGridTextColumn Header="Hạn xử lý"
                                                        Binding="{Binding DueDate}"
                                                        Width="120"
                                                        ElementStyle="{StaticResource RecentGridMutedTextStyle}"/>

                                    <DataGridTextColumn Header="Cập nhật"
                                                        Binding="{Binding UpdatedAt, StringFormat=dd/MM/yyyy HH:mm}"
                                                        Width="150"
                                                        ElementStyle="{StaticResource RecentGridMutedTextStyle}"/>
                                </DataGrid.Columns>
                            </DataGrid>
                        </StackPanel>
                    </Border>

                    <Border Grid.Column="1"
                            Style="{StaticResource AppCardStyle}">
                        <StackPanel>
                            <TextBlock Text="Văn bản theo phòng ban"
                                       Style="{StaticResource SectionTitleTextStyle}"
                                       Margin="0,0,0,12"/>

                            <Grid Height="330">
                                <lvc:CartesianChart Series="{Binding DepartmentIssuedSeries}"
                                                    LegendLocation="Top">
                                    <lvc:CartesianChart.AxisX>
                                        <lvc:Axis Labels="{Binding DepartmentIssuedLabels}"
                                                  Separator="{x:Static lvc:DefaultAxes.CleanSeparator}"/>
                                    </lvc:CartesianChart.AxisX>
                                    <lvc:CartesianChart.AxisY>
                                        <lvc:Axis MinValue="0"/>
                                    </lvc:CartesianChart.AxisY>

                                    <lvc:CartesianChart.Style>
                                        <Style TargetType="lvc:CartesianChart">
                                            <Setter Property="Visibility" Value="Visible"/>
                                            <Style.Triggers>
                                                <DataTrigger Binding="{Binding HasDepartmentIssuedChartData}" Value="False">
                                                    <Setter Property="Visibility" Value="Collapsed"/>
                                                </DataTrigger>
                                            </Style.Triggers>
                                        </Style>
                                    </lvc:CartesianChart.Style>
                                </lvc:CartesianChart>

                                <Border>
                                    <Border.Style>
                                        <Style TargetType="Border" BasedOn="{StaticResource SoftCardStyle}">
                                            <Setter Property="Visibility" Value="Collapsed"/>
                                            <Style.Triggers>
                                                <DataTrigger Binding="{Binding HasDepartmentIssuedChartData}" Value="False">
                                                    <Setter Property="Visibility" Value="Visible"/>
                                                </DataTrigger>
                                            </Style.Triggers>
                                        </Style>
                                    </Border.Style>

                                    <TextBlock Text="Chưa có dữ liệu phòng ban"
                                               HorizontalAlignment="Center"
                                               VerticalAlignment="Center"
                                               Style="{StaticResource MutedTextStyle}"/>
                                </Border>
                            </Grid>
                        </StackPanel>
                    </Border>
                </Grid>

            </StackPanel>
        </ScrollViewer>

        <Grid Style="{StaticResource LoadingOverlayGridStyle}"
              Visibility="{Binding IsLoading, Converter={StaticResource BoolToVisibility}}">

            <Border Style="{StaticResource LoadingCardStyle}">
                <StackPanel HorizontalAlignment="Center"
                            VerticalAlignment="Center">
                    <ProgressBar Width="140"
                                 Height="6"
                                 IsIndeterminate="True"
                                 Margin="0,0,0,18"/>

                    <TextBlock Text="Đang tải dashboard..."
                               Style="{StaticResource LoadingTextStyle}"/>
                </StackPanel>
            </Border>
        </Grid>

        <Border Style="{StaticResource ErrorBannerStyle}"
                Visibility="{Binding HasError, Converter={StaticResource BoolToVisibility}}">
            <TextBlock Text="{Binding ErrorMessage}"
                       Style="{StaticResource ErrorBannerTextStyle}"/>
        </Border>
    </Grid>
</UserControl>