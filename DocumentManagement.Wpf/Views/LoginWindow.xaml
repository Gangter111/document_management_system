<Window x:Class="DocumentManagement.Wpf.Views.LoginWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        mc:Ignorable="d"
        Title="Đăng nhập hệ thống"
        Height="560"
        Width="960"
        MinHeight="560"
        MinWidth="960"
        WindowStartupLocation="CenterScreen"
        ResizeMode="NoResize"
        Background="#09111F"
        FontFamily="Segoe UI">

    <Window.Resources>
        <SolidColorBrush x:Key="PrimaryTextBrush" Color="#111827"/>
        <SolidColorBrush x:Key="SecondaryTextBrush" Color="#6B7280"/>
        <SolidColorBrush x:Key="MutedTextBrush" Color="#9CA3AF"/>
        <SolidColorBrush x:Key="DangerBrush" Color="#DC2626"/>

        <SolidColorBrush x:Key="GlassBorderBrush" Color="#80FFFFFF"/>
        <SolidColorBrush x:Key="InputBorderBrush" Color="#A7B0C0"/>
        <SolidColorBrush x:Key="InputBackgroundBrush" Color="#CCFFFFFF"/>

        <!-- Premium button colors -->
        <SolidColorBrush x:Key="AccentButtonBrush" Color="#1D4ED8"/>
        <SolidColorBrush x:Key="AccentButtonHoverBrush" Color="#1E40AF"/>

        <LinearGradientBrush x:Key="BackgroundGradientBrush" StartPoint="0,0" EndPoint="1,1">
            <GradientStop Color="#050B19" Offset="0"/>
            <GradientStop Color="#081228" Offset="0.35"/>
            <GradientStop Color="#07101F" Offset="0.7"/>
            <GradientStop Color="#040812" Offset="1"/>
        </LinearGradientBrush>

        <Style x:Key="RoundedInputTextBoxStyle" TargetType="TextBox">
            <Setter Property="Height" Value="42"/>
            <Setter Property="Foreground" Value="{StaticResource PrimaryTextBrush}"/>
            <Setter Property="Background" Value="{StaticResource InputBackgroundBrush}"/>
            <Setter Property="BorderBrush" Value="{StaticResource InputBorderBrush}"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="FontSize" Value="13"/>
            <Setter Property="Padding" Value="14,0,36,0"/>
            <Setter Property="VerticalContentAlignment" Value="Center"/>
            <Setter Property="CaretBrush" Value="#111827"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="TextBox">
                        <Border Background="{TemplateBinding Background}"
                                BorderBrush="{TemplateBinding BorderBrush}"
                                BorderThickness="{TemplateBinding BorderThickness}"
                                CornerRadius="21">
                            <ScrollViewer x:Name="PART_ContentHost"
                                          Margin="{TemplateBinding Padding}"
                                          VerticalAlignment="Center"/>
                        </Border>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Style x:Key="RoundedPasswordBoxStyle" TargetType="PasswordBox">
            <Setter Property="Height" Value="42"/>
            <Setter Property="Foreground" Value="{StaticResource PrimaryTextBrush}"/>
            <Setter Property="Background" Value="{StaticResource InputBackgroundBrush}"/>
            <Setter Property="BorderBrush" Value="{StaticResource InputBorderBrush}"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="FontSize" Value="13"/>
            <Setter Property="Padding" Value="14,0,36,0"/>
            <Setter Property="VerticalContentAlignment" Value="Center"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="PasswordBox">
                        <Border Background="{TemplateBinding Background}"
                                BorderBrush="{TemplateBinding BorderBrush}"
                                BorderThickness="{TemplateBinding BorderThickness}"
                                CornerRadius="21">
                            <ScrollViewer x:Name="PART_ContentHost"
                                          Margin="{TemplateBinding Padding}"
                                          VerticalAlignment="Center"/>
                        </Border>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Style x:Key="AccentButtonStyle" TargetType="Button">
            <Setter Property="Height" Value="42"/>
            <Setter Property="Background" Value="{StaticResource AccentButtonBrush}"/>
            <Setter Property="Foreground" Value="White"/>
            <Setter Property="BorderBrush" Value="{StaticResource AccentButtonBrush}"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="FontWeight" Value="SemiBold"/>
            <Setter Property="FontSize" Value="13"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border Background="{TemplateBinding Background}"
                                CornerRadius="21">
                            <ContentPresenter HorizontalAlignment="Center"
                                              VerticalAlignment="Center"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter Property="Background" Value="{StaticResource AccentButtonHoverBrush}"/>
                            </Trigger>
                            <Trigger Property="IsPressed" Value="True">
                                <Setter Property="Opacity" Value="0.92"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Style x:Key="SecondaryButtonStyle" TargetType="Button">
            <Setter Property="Height" Value="40"/>
            <Setter Property="Background" Value="#DCE4F5"/>
            <Setter Property="Foreground" Value="#374151"/>
            <Setter Property="BorderBrush" Value="#BFC9D9"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="FontWeight" Value="SemiBold"/>
            <Setter Property="FontSize" Value="12"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border Background="{TemplateBinding Background}"
                                BorderBrush="{TemplateBinding BorderBrush}"
                                BorderThickness="{TemplateBinding BorderThickness}"
                                CornerRadius="20">
                            <ContentPresenter HorizontalAlignment="Center"
                                              VerticalAlignment="Center"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter Property="Background" Value="#CED8EC"/>
                            </Trigger>
                            <Trigger Property="IsPressed" Value="True">
                                <Setter Property="Opacity" Value="0.92"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>
    </Window.Resources>

    <Grid Background="{StaticResource BackgroundGradientBrush}">
        <!-- Background decoration -->
        <Canvas IsHitTestVisible="False">
            <Polygon Points="0,46 240,0 520,0 120,180"
                     Fill="#16FFFFFF"/>
            <Polygon Points="0,120 330,0 700,0 160,250"
                     Fill="#0EA5E920"/>
            <Polygon Points="0,360 300,220 520,320 120,520"
                     Fill="#84CC1628"/>
            <Polygon Points="420,0 760,0 960,120 700,200"
                     Fill="#22D3EE20"/>
            <Polygon Points="540,220 960,120 960,330 700,390"
                     Fill="#A3E63522"/>
            <Polygon Points="0,500 260,360 420,470 150,560"
                     Fill="#EC489930"/>
        </Canvas>

        <Grid>
            <Border Width="290"
                    Height="470"
                    HorizontalAlignment="Center"
                    VerticalAlignment="Center"
                    BorderBrush="{StaticResource GlassBorderBrush}"
                    BorderThickness="1"
                    CornerRadius="24"
                    Padding="24">
                <Border.Background>
                    <SolidColorBrush Color="#55FFFFFF"/>
                </Border.Background>

                <Border.Effect>
                    <DropShadowEffect Color="#000000"
                                      BlurRadius="30"
                                      ShadowDepth="10"
                                      Opacity="0.26"/>
                </Border.Effect>

                <Grid>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="16"/>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="18"/>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="12"/>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="14"/>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="14"/>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="*"/>
                    </Grid.RowDefinitions>

                    <!-- Top logo circle -->
                    <Grid Grid.Row="0"
                          HorizontalAlignment="Center">
                        <Ellipse Width="82"
                                 Height="82"
                                 Fill="#EAF1FB"
                                 Stroke="#C6D2E3"
                                 StrokeThickness="2"/>

                        <Border Width="64"
                                Height="64"
                                Background="#FFFFFF"
                                CornerRadius="32"
                                Padding="8"
                                HorizontalAlignment="Center"
                                VerticalAlignment="Center">
                            <Border.Effect>
                                <DropShadowEffect Color="#0F172A"
                                                  BlurRadius="10"
                                                  ShadowDepth="2"
                                                  Opacity="0.12"/>
                            </Border.Effect>

                            <Image Source="pack://application:,,,/Assets/Images/logo-tach.png"
                                   Stretch="Uniform"/>
                        </Border>
                    </Grid>

                    <!-- Centered brand -->
                    <StackPanel Grid.Row="2"
                                HorizontalAlignment="Center">
                        <TextBlock Text="PHU GIA GROUP"
                                   Foreground="{StaticResource PrimaryTextBrush}"
                                   FontSize="13"
                                   FontWeight="Bold"
                                   TextAlignment="Center"
                                   HorizontalAlignment="Center"/>
                        <TextBlock Text="Login"
                                   Margin="0,4,0,0"
                                   Foreground="{StaticResource SecondaryTextBrush}"
                                   FontSize="12"
                                   TextAlignment="Center"
                                   HorizontalAlignment="Center"/>
                    </StackPanel>

                    <!-- Username -->
                    <Grid Grid.Row="4">
                        <TextBox x:Name="UsernameTextBox"
                                 Style="{StaticResource RoundedInputTextBoxStyle}"/>
                        <TextBlock Text="✕"
                                   FontSize="11"
                                   Foreground="{StaticResource MutedTextBrush}"
                                   HorizontalAlignment="Right"
                                   VerticalAlignment="Center"
                                   Margin="0,0,14,0"/>
                    </Grid>

                    <!-- Password -->
                    <Grid Grid.Row="6">
                        <PasswordBox x:Name="PasswordBox"
                                     Style="{StaticResource RoundedPasswordBoxStyle}"/>
                        <TextBlock Text="◉"
                                   FontSize="10"
                                   Foreground="{StaticResource MutedTextBrush}"
                                   HorizontalAlignment="Right"
                                   VerticalAlignment="Center"
                                   Margin="0,0,14,0"/>
                    </Grid>

                    <!-- Remember / forgot -->
                    <Grid Grid.Row="8">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="Auto"/>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="Auto"/>
                        </Grid.ColumnDefinitions>

                        <CheckBox Grid.Column="0"
                                  VerticalAlignment="Center"
                                  Margin="0,0,8,0"/>

                        <TextBlock Grid.Column="1"
                                   VerticalAlignment="Center"
                                   Foreground="{StaticResource SecondaryTextBrush}"
                                   FontSize="10"
                                   Text="Remember me"/>

                        <TextBlock Grid.Column="2"
                                   VerticalAlignment="Center"
                                   Foreground="{StaticResource SecondaryTextBrush}"
                                   FontSize="10"
                                   Text="Forgot password?"/>
                    </Grid>

                    <!-- Error -->
                    <TextBlock x:Name="ErrorText"
                               Grid.Row="10"
                               Foreground="{StaticResource DangerBrush}"
                               FontSize="11"
                               TextWrapping="Wrap"
                               FontWeight="SemiBold"
                               TextAlignment="Center"/>

                    <!-- Buttons -->
                    <StackPanel Grid.Row="11"
                                VerticalAlignment="Center"
                                Margin="0,12,0,0">
                        <Button Style="{StaticResource AccentButtonStyle}"
                                Click="LoginButton_Click"
                                Content="Login"/>

                        <Button Margin="0,12,0,0"
                                Style="{StaticResource SecondaryButtonStyle}"
                                Click="ExitButton_Click"
                                Content="Thoát"/>
                    </StackPanel>
                </Grid>
            </Border>
        </Grid>
    </Grid>
</Window>