<Window x:Class="DocumentManagement.Wpf.Views.DocumentDetailWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Chi tiết văn bản" Height="700" Width="900" WindowStartupLocation="CenterOwner">
    <Grid Margin="25">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <StackPanel Margin="0,0,0,25">
            <TextBlock Text="{Binding Document.Title}" FontSize="24" FontWeight="Bold" TextWrapping="Wrap"/>
            <TextBlock Text="{Binding Document.DocumentNumber}" Foreground="#6B7280" FontSize="16" Margin="0,5,0,0"/>
        </StackPanel>

        <Grid Grid.Row="1">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="2*"/>
                <ColumnDefinition Width="1.5*"/>
            </Grid.ColumnDefinitions>

            <ScrollViewer Margin="0,0,20,0">
                <StackPanel>
                    <TextBlock Text="Trích yếu nội dung" FontWeight="Bold" Margin="0,0,0,5"/>
                    <TextBlock Text="{Binding Document.Summary}" TextWrapping="Wrap" Margin="0,0,0,20"/>

                    <TextBlock Text="Nội dung trích xuất" FontWeight="Bold" Margin="0,0,0,5"/>
                    <Border Background="#F9FAFB" Padding="15" CornerRadius="8">
                        <TextBlock Text="{Binding Document.ContentText}" TextWrapping="Wrap"/>
                    </Border>
                </StackPanel>
            </ScrollViewer>

            <StackPanel Grid.Column="1">
                <TextBlock Text="Thông tin chung" FontWeight="Bold" Margin="0,0,0,10"/>
                <ItemsControl>
                    <StackPanel Margin="0,0,0,10">
                        <TextBlock Text="Loại văn bản:" Foreground="#6B7280"/>
                        <TextBlock Text="{Binding Document.DocumentType}" FontWeight="SemiBold"/>
                    </StackPanel>
                    <StackPanel Margin="0,0,0,10">
                        <TextBlock Text="Ngày văn bản:" Foreground="#6B7280"/>
                        <TextBlock Text="{Binding Document.IssueDate}" FontWeight="SemiBold"/>
                    </StackPanel>
                    <StackPanel Margin="0,0,0,10">
                        <TextBlock Text="Độ khẩn:" Foreground="#6B7280"/>
                        <TextBlock Text="{Binding Document.UrgencyLevel}" FontWeight="SemiBold"/>
                    </StackPanel>
                </ItemsControl>

                <Separator Margin="0,15"/>

                <TextBlock Text="Tệp đính kèm" FontWeight="Bold" Margin="0,0,0,10"/>
                <ItemsControl ItemsSource="{Binding Attachments}">
                    <ItemsControl.ItemTemplate>
                        <DataTemplate>
                            <Border BorderBrush="#E5E7EB" BorderThickness="1" CornerRadius="4" Padding="10" Margin="0,0,0,8">
                                <DockPanel>
                                    <Button Content="Mở File" DockPanel.Dock="Right" 
                                            Command="{Binding DataContext.OpenAttachmentCommand, RelativeSource={RelativeSource AncestorType=ItemsControl}}"
                                            CommandParameter="{Binding}"/>
                                    <TextBlock Text="{Binding OriginalFileName}" VerticalAlignment="Center" TextTrimming="CharacterEllipsis"/>
                                </DockPanel>
                            </Border>
                        </DataTemplate>
                    </ItemsControl.ItemTemplate>
                </ItemsControl>
            </StackPanel>
        </Grid>

        <Button Grid.Row="2" Content="Đóng" HorizontalAlignment="Right" Width="100" Margin="0,20,0,0" IsDefault="True" Click="CloseButton_Click"/>
    </Grid>
</Window>
