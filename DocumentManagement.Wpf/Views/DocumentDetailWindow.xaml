<Window x:Class="DocumentManagement.Wpf.Views.DocumentDetailWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:materialDesign="http://materialdesigninxaml.net/winfx/xaml/themes"
        Title="Chi tiết văn bản"
        Height="760"
        Width="940"
        WindowStartupLocation="CenterOwner"
        Background="{StaticResource AppBackgroundBrush}"
        FontFamily="{StaticResource AppFontFamily}">

    <Window.Resources>
        <Style x:Key="InfoLabelStyle" TargetType="TextBlock">
            <Setter Property="FontSize" Value="12"/>
            <Setter Property="Foreground" Value="{StaticResource TextMutedBrush}"/>
        </Style>

        <Style x:Key="InfoValueStyle" TargetType="TextBlock">
            <Setter Property="FontSize" Value="12"/>
            <Setter Property="FontWeight" Value="SemiBold"/>
            <Setter Property="Foreground" Value="{StaticResource TextBrush}"/>
            <Setter Property="TextTrimming" Value="CharacterEllipsis"/>
        </Style>

        <Style x:Key="ToolbarButtonStyle" TargetType="Button" BasedOn="{StaticResource SecondaryButtonStyle}">
            <Setter Property="Height" Value="32"/>
            <Setter Property="Padding" Value="12,0"/>
            <Setter Property="Margin" Value="0,0,8,0"/>
            <Setter Property="FontSize" Value="12"/>
        </Style>
    </Window.Resources>

    <Grid Margin="22">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="14"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="14"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>

        <Grid Grid.Row="0">
            <TextBlock Text="CHI TIẾT VĂN BẢN"
                       FontSize="18"
                       FontWeight="Bold"
                       Foreground="{StaticResource TextBrush}"
                       VerticalAlignment="Center"/>

            <StackPanel Orientation="Horizontal" HorizontalAlignment="Right">
                <Button Style="{StaticResource ToolbarButtonStyle}">
                    <StackPanel Orientation="Horizontal">
                        <materialDesign:PackIcon Kind="PencilOutline" Width="14" Height="14" VerticalAlignment="Center"/>
                        <TextBlock Text="Sửa" Margin="6,0,0,0" VerticalAlignment="Center"/>
                    </StackPanel>
                </Button>
                <Button Style="{StaticResource ToolbarButtonStyle}">
                    <StackPanel Orientation="Horizontal">
                        <materialDesign:PackIcon Kind="PrinterOutline" Width="14" Height="14" VerticalAlignment="Center"/>
                        <TextBlock Text="In" Margin="6,0,0,0" VerticalAlignment="Center"/>
                    </StackPanel>
                </Button>
                <Button Style="{StaticResource ToolbarButtonStyle}">
                    <StackPanel Orientation="Horizontal">
                        <materialDesign:PackIcon Kind="DownloadOutline" Width="14" Height="14" VerticalAlignment="Center"/>
                        <TextBlock Text="Tải xuống" Margin="6,0,0,0" VerticalAlignment="Center"/>
                    </StackPanel>
                </Button>
                <Button Style="{StaticResource SuccessButtonStyle}" Height="32" Padding="12,0" Margin="0,0,8,0">
                    <StackPanel Orientation="Horizontal">
                        <materialDesign:PackIcon Kind="CheckCircleOutline" Width="14" Height="14" VerticalAlignment="Center"/>
                        <TextBlock Text="Đã duyệt" Margin="6,0,0,0" VerticalAlignment="Center"/>
                    </StackPanel>
                </Button>
                <Button Style="{StaticResource ToolbarButtonStyle}" Content="Khác"/>
                <Button Style="{StaticResource ToolbarButtonStyle}" Click="CloseButton_Click" Content="Đóng"/>
            </StackPanel>
        </Grid>

        <Border Grid.Row="2"
                Style="{StaticResource AppCardStyle}">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="58"/>
                    <ColumnDefinition Width="1.15*"/>
                    <ColumnDefinition Width="1*"/>
                </Grid.ColumnDefinitions>

                <Border Width="40"
                        Height="48"
                        CornerRadius="6"
                        Background="#E8F7EF"
                        BorderBrush="#BEE3CB"
                        BorderThickness="1"
                        VerticalAlignment="Top">
                    <materialDesign:PackIcon Kind="FileDocumentOutline"
                                             Width="24"
                                             Height="24"
                                             Foreground="{StaticResource PrimaryBrush}"
                                             HorizontalAlignment="Center"
                                             VerticalAlignment="Center"/>
                </Border>

                <StackPanel Grid.Column="1">
                    <TextBlock Text="{Binding Document.DocumentType}"
                               FontSize="12"
                               Foreground="{StaticResource TextMutedBrush}"/>
                    <StackPanel Orientation="Horizontal" Margin="0,2,0,0">
                        <TextBlock Text="{Binding Document.DocumentNumber}"
                                   FontSize="24"
                                   FontWeight="Bold"
                                   Foreground="{StaticResource TextBrush}"
                                   VerticalAlignment="Center"/>
                        <Border Background="#DCFCE7"
                                CornerRadius="12"
                                Padding="9,3"
                                Margin="12,0,0,0"
                                VerticalAlignment="Center">
                            <TextBlock Text="{Binding Document.StatusText}"
                                       FontSize="10"
                                       FontWeight="SemiBold"
                                       Foreground="#087A3D"/>
                        </Border>
                    </StackPanel>
                </StackPanel>

                <Grid Grid.Column="2">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="1*"/>
                        <ColumnDefinition Width="1*"/>
                    </Grid.ColumnDefinitions>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="10"/>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="10"/>
                        <RowDefinition Height="Auto"/>
                    </Grid.RowDefinitions>

                    <StackPanel Grid.Row="0" Grid.Column="0">
                        <TextBlock Text="Cơ quan ban hành" Style="{StaticResource InfoLabelStyle}"/>
                        <TextBlock Text="{Binding Document.SenderName}" Style="{StaticResource InfoValueStyle}"/>
                    </StackPanel>
                    <StackPanel Grid.Row="0" Grid.Column="1">
                        <TextBlock Text="Số trang" Style="{StaticResource InfoLabelStyle}"/>
                        <TextBlock Text="05" Style="{StaticResource InfoValueStyle}"/>
                    </StackPanel>
                    <StackPanel Grid.Row="2" Grid.Column="0">
                        <TextBlock Text="Ngày ban hành" Style="{StaticResource InfoLabelStyle}"/>
                        <TextBlock Text="{Binding Document.IssueDate}" Style="{StaticResource InfoValueStyle}"/>
                    </StackPanel>
                    <StackPanel Grid.Row="2" Grid.Column="1">
                        <TextBlock Text="Người ký" Style="{StaticResource InfoLabelStyle}"/>
                        <TextBlock Text="{Binding Document.SignerName}" Style="{StaticResource InfoValueStyle}"/>
                    </StackPanel>
                    <StackPanel Grid.Row="4" Grid.Column="0">
                        <TextBlock Text="Loại văn bản" Style="{StaticResource InfoLabelStyle}"/>
                        <TextBlock Text="{Binding Document.DocumentType}" Style="{StaticResource InfoValueStyle}"/>
                    </StackPanel>
                    <StackPanel Grid.Row="4" Grid.Column="1">
                        <TextBlock Text="Nơi nhận" Style="{StaticResource InfoLabelStyle}"/>
                        <TextBlock Text="{Binding Document.ReceiverName}" Style="{StaticResource InfoValueStyle}"/>
                    </StackPanel>
                </Grid>
            </Grid>
        </Border>

        <Grid Grid.Row="4">
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="*"/>
            </Grid.RowDefinitions>

            <StackPanel Orientation="Horizontal" Margin="0,0,0,10">
                <TextBlock Text="NỘI DUNG" FontSize="12" FontWeight="Bold" Foreground="{StaticResource PrimaryBrush}" Margin="0,0,30,0"/>
                <TextBlock Text="NƠI NHẬN" FontSize="12" FontWeight="SemiBold" Foreground="{StaticResource TextMutedBrush}" Margin="0,0,30,0"/>
                <TextBlock Text="LỊCH SỬ XỬ LÝ" FontSize="12" FontWeight="SemiBold" Foreground="{StaticResource TextMutedBrush}" Margin="0,0,30,0"/>
                <TextBlock Text="TỆP ĐÍNH KÈM" FontSize="12" FontWeight="SemiBold" Foreground="{StaticResource TextMutedBrush}"/>
            </StackPanel>

            <Border Grid.Row="1"
                    Style="{StaticResource AppCardStyle}">
                <ScrollViewer VerticalScrollBarVisibility="Auto">
                    <StackPanel>
                        <TextBlock Text="{Binding Document.Summary}"
                                   FontSize="13"
                                   FontWeight="SemiBold"
                                   Foreground="{StaticResource TextBrush}"
                                   TextWrapping="Wrap"
                                   Margin="0,0,0,14"/>
                        <TextBlock Text="{Binding Document.ContentText}"
                                   FontSize="13"
                                   Foreground="{StaticResource TextBrush}"
                                   TextWrapping="Wrap"
                                   LineHeight="24"/>
                        <ItemsControl ItemsSource="{Binding Attachments}" Margin="0,18,0,0">
                            <ItemsControl.ItemTemplate>
                                <DataTemplate>
                                    <Border BorderBrush="{StaticResource BorderBrushDefault}"
                                            BorderThickness="1"
                                            CornerRadius="6"
                                            Padding="10"
                                            Margin="0,0,0,8">
                                        <DockPanel>
                                            <Button Content="Mở file"
                                                    DockPanel.Dock="Right"
                                                    Style="{StaticResource SecondaryButtonStyle}"
                                                    Height="30"
                                                    Command="{Binding DataContext.OpenAttachmentCommand, RelativeSource={RelativeSource AncestorType=ItemsControl}}"
                                                    CommandParameter="{Binding}"/>
                                            <TextBlock Text="{Binding FileName}"
                                                       VerticalAlignment="Center"
                                                       TextTrimming="CharacterEllipsis"/>
                                        </DockPanel>
                                    </Border>
                                </DataTemplate>
                            </ItemsControl.ItemTemplate>
                        </ItemsControl>
                    </StackPanel>
                </ScrollViewer>
            </Border>
        </Grid>
    </Grid>
</Window>
